---
// Admin → Novo produto: o mínimo para nascer (princípio do modelo aprovado:
// preencha pouco, o sistema deriva o resto). Detalhes na tela de edição.
import { eq } from 'drizzle-orm';
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { db, tabelas } from '../../../db';
import { carregarCategorias, parseChips, slugify } from '../../../lib/catalogo';

export const prerender = false;

const categorias = await carregarCategorias();
let erro = '';

if (Astro.request.method === 'POST') {
  const f = await Astro.request.formData();
  const texto = (k: string) => String(f.get(k) ?? '').trim();

  const nome = texto('nome');
  const categoriaId = Number(texto('categoriaId'));

  if (!nome || !categoriaId) {
    erro = 'Preencha o nome do produto e a categoria.';
  } else {
    // Slug é opcional na criação: se vier em branco, fica sem slug e a tela
    // de edição sugere um a partir do nome (regra aprovada pelo cliente).
    let slug: string | null = slugify(texto('slug')) || null;
    if (slug) {
      const [jaExiste] = await db
        .select({ id: tabelas.produtos.id })
        .from(tabelas.produtos)
        .where(eq(tabelas.produtos.slug, slug));
      if (jaExiste) slug = `${slug}-${Date.now().toString(36)}`;
    }

    const [novo] = await db
      .insert(tabelas.produtos)
      .values({
        slug,
        nome,
        categoriaId,
        specsChips: parseChips(texto('specsChips')),
        publicado: false, // nasce como rascunho — publicar na edição
      })
      .returning({ id: tabelas.produtos.id });
    return Astro.redirect(`/admin/produtos/${novo.id}?ok=criado`);
  }
}
---

<AdminLayout titulo="Novo produto">
  <div class="acoes">
    <h1>Novo produto</h1>
    <a class="voltar" href="/admin/produtos">← Todos os produtos</a>
  </div>

  {erro && <p class="flash erro" role="alert">{erro}</p>}

  <form method="POST">
    <div class="cartao-form" style="max-width:760px">
      <h2>Só o essencial para começar</h2>
      <p class="nota">
        Informe o nome do produto e a categoria. O produto nasce como rascunho;
        o conteúdo da página e o endereço (slug) você completa na próxima tela.
      </p>
      <div class="campos">
        <label class="campo">
          Nome do produto <span class="req" aria-hidden="true">*</span>
          <input
            type="text"
            name="nome"
            placeholder="Compressor Elétrico Portátil E-AIR T500"
            required
            autofocus
          />
          <span class="dica">Nome completo, como deve aparecer no site (este é o título da página).</span>
        </label>
        <label class="campo">
          Categoria <span class="req" aria-hidden="true">*</span>
          <select name="categoriaId" required>
            <option value="">Selecione…</option>
            {categorias.map((c) => (
              <option value={c.id}>{c.nome}</option>
            ))}
          </select>
        </label>
        <label class="campo">
          Chips do card (separados por vírgula)
          <input type="text" name="specsChips" placeholder="144 kVA, Diesel, Carenado" />
        </label>
        <label class="campo">
          Slug do endereço (opcional)
          <input type="text" name="slug" placeholder="deixe em branco — sugerimos depois pelo nome" />
          <span class="dica">Se deixar em branco, a próxima tela sugere um slug a partir do nome.</span>
        </label>
      </div>
      <p style="margin-top:1.25rem">
        <button class="botao" type="submit">Criar rascunho</button>
      </p>
    </div>
  </form>
</AdminLayout>
