---
// Admin → Produtos: lista com busca e filtro por categoria.
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { nomeProduto, imagemPrincipal, temPaginaPropria } from '../../../data/produtos';
import { carregarCategorias, carregarProdutos } from '../../../lib/catalogo';

export const prerender = false;

const categorias = await carregarCategorias();
const todos = await carregarProdutos();

const q = (Astro.url.searchParams.get('q') ?? '').trim().toLowerCase();
const cat = Astro.url.searchParams.get('cat') ?? '';

const nomeCategoria = new Map(categorias.map((c) => [c.slug, c.nomeCurto]));

let itens = todos;
if (cat) itens = itens.filter((p) => p.categoria === cat);
if (q) {
  itens = itens.filter((p) => `${p.nome} ${p.slug}`.toLowerCase().includes(q));
}

// Ordenação por coluna. Padrão: mais recente primeiro (data ↓).
type Coluna = 'nome' | 'categoria' | 'status' | 'data';
const colunasValidas: Coluna[] = ['nome', 'categoria', 'status', 'data'];
const sortParam = Astro.url.searchParams.get('sort');
const sort: Coluna = colunasValidas.includes(sortParam as Coluna)
  ? (sortParam as Coluna)
  : 'data';
const dir = Astro.url.searchParams.get('dir') === 'asc' ? 'asc' : 'desc';
const fator = dir === 'asc' ? 1 : -1;

const cmpTexto = (a: string, b: string) => a.localeCompare(b, 'pt-BR', { sensitivity: 'base' });

itens = [...itens].sort((a, b) => {
  switch (sort) {
    case 'nome':
      return fator * cmpTexto(nomeProduto(a), nomeProduto(b));
    case 'categoria':
      return (
        fator *
        cmpTexto(
          nomeCategoria.get(a.categoria) ?? a.categoria,
          nomeCategoria.get(b.categoria) ?? b.categoria,
        )
      );
    case 'status': {
      // publicado (1) acima de rascunho (0) na ordem decrescente
      const va = a.publicado !== false ? 1 : 0;
      const vb = b.publicado !== false ? 1 : 0;
      return fator * (va - vb);
    }
    case 'data':
    default:
      return fator * (new Date(a.criadoEm).getTime() - new Date(b.criadoEm).getTime());
  }
});

// Monta o link de um cabeçalho, preservando busca/filtro e alternando a direção.
// Direção inicial ao escolher uma coluna nova: data ↓ (recente), demais ↑ (A–Z).
function linkOrdenacao(coluna: Coluna): string {
  const params = new URLSearchParams();
  if (q) params.set('q', q);
  if (cat) params.set('cat', cat);
  let novaDir: 'asc' | 'desc';
  if (sort === coluna) {
    novaDir = dir === 'asc' ? 'desc' : 'asc';
  } else {
    novaDir = coluna === 'data' ? 'desc' : 'asc';
  }
  params.set('sort', coluna);
  params.set('dir', novaDir);
  return `/admin/produtos?${params.toString()}`;
}
const seta = (coluna: Coluna) => (sort === coluna ? (dir === 'asc' ? ' ↑' : ' ↓') : '');

const fmtData = new Intl.DateTimeFormat('pt-BR', {
  day: '2-digit',
  month: '2-digit',
  year: 'numeric',
});

const excluido = Astro.url.searchParams.get('ok') === 'excluido';
const filtrando = Boolean(q || cat);
---

<AdminLayout titulo="Produtos">
  <div class="acoes">
    <h1>
      Produtos
      <span class="contagem">{filtrando ? `${itens.length} de ${todos.length}` : todos.length}</span>
    </h1>
    <a class="botao" href="/admin/produtos/novo">+ Novo produto</a>
  </div>

  {excluido && <p class="flash" role="status">Produto excluído.</p>}

  <form method="GET" class="toolbar" role="search">
    <input
      type="search"
      name="q"
      value={q}
      placeholder="Buscar por código, tipo ou nome…"
      aria-label="Buscar produtos"
    />
    <select name="cat" aria-label="Filtrar por categoria">
      <option value="">Todas as categorias</option>
      {categorias.map((c) => (
        <option value={c.slug} selected={c.slug === cat}>
          {c.nome}
        </option>
      ))}
    </select>
    <button class="botao cinza" type="submit">Filtrar</button>
    {filtrando && <a class="limpar" href="/admin/produtos">Limpar</a>}
  </form>

  <div class="tabela-rolagem">
    <table class="lista">
      <thead>
        <tr>
          <th scope="col"><span class="sr-only">Foto</span></th>
          <th scope="col" aria-sort={sort === 'nome' ? (dir === 'asc' ? 'ascending' : 'descending') : 'none'}>
            <a class={`ord ${sort === 'nome' ? 'ativo' : ''}`} href={linkOrdenacao('nome')}>
              Produto{seta('nome')}
            </a>
          </th>
          <th scope="col" aria-sort={sort === 'categoria' ? (dir === 'asc' ? 'ascending' : 'descending') : 'none'}>
            <a class={`ord ${sort === 'categoria' ? 'ativo' : ''}`} href={linkOrdenacao('categoria')}>
              Categoria{seta('categoria')}
            </a>
          </th>
          <th scope="col" aria-sort={sort === 'status' ? (dir === 'asc' ? 'ascending' : 'descending') : 'none'}>
            <a class={`ord ${sort === 'status' ? 'ativo' : ''}`} href={linkOrdenacao('status')}>
              Status{seta('status')}
            </a>
          </th>
          <th scope="col" aria-sort={sort === 'data' ? (dir === 'asc' ? 'ascending' : 'descending') : 'none'}>
            <a class={`ord ${sort === 'data' ? 'ativo' : ''}`} href={linkOrdenacao('data')}>
              Data{seta('data')}
            </a>
          </th>
          <th scope="col"><span class="sr-only">Ações</span></th>
        </tr>
      </thead>
      <tbody>
        {
          itens.length === 0 && (
            <tr>
              <td colspan="6" class="vazio">
                <b>Nenhum produto encontrado.</b>
                <br />
                Tente outra busca ou <a href="/admin/produtos">limpe os filtros</a>.
              </td>
            </tr>
          )
        }
        {
          itens.map((p) => {
            const img = imagemPrincipal(p);
            return (
              <tr>
                <td style="width:62px">
                  {img && <img class="mini-foto" src={img.src} alt="" loading="lazy" />}
                </td>
                <td>
                  <a class="nome-produto" href={`/admin/produtos/${p.id}`}>
                    {nomeProduto(p)}
                  </a>
                  <br />
                  <span class="secundario">
                    {p.slug ? `/${p.slug}` : 'sem slug — defina na edição'}
                  </span>
                </td>
                <td>{nomeCategoria.get(p.categoria) ?? p.categoria}</td>
                <td>
                  {p.publicado !== false ? (
                    <span class="badge ok">Publicado</span>
                  ) : (
                    <span class="badge off">Rascunho</span>
                  )}
                  {p.destaque && <span class="badge dest">Destaque</span>}
                  {temPaginaPropria(p) && <span class="badge info">Página própria</span>}
                </td>
                <td>
                  <time class="data" datetime={new Date(p.criadoEm).toISOString()}>
                    {fmtData.format(new Date(p.criadoEm))}
                  </time>
                </td>
                <td>
                  <div class="acoes-linha">
                    <a class="botao mini cinza" href={`/admin/produtos/${p.id}`}>
                      Editar
                    </a>
                    <form
                      method="POST"
                      action={`/admin/produtos/${p.id}`}
                      onsubmit="return confirm('Excluir este produto? Remove imagens e especificações. Esta ação não tem volta.')"
                    >
                      <input type="hidden" name="_acao" value="excluir" />
                      <button class="botao mini perigo" type="submit">Excluir</button>
                    </form>
                  </div>
                </td>
              </tr>
            );
          })
        }
      </tbody>
    </table>
  </div>
</AdminLayout>

<style>
  .contagem {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--ink-2);
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.1rem 0.6rem;
    vertical-align: 3px;
    margin-left: 0.4rem;
  }
  .toolbar { display: flex; gap: 0.6rem; flex-wrap: wrap; align-items: center; margin-bottom: 1rem; }
  .toolbar input[type='search'] {
    flex: 1;
    min-width: 220px;
    padding: 0.6rem 0.8rem;
    border: 1px solid var(--line-strong);
    border-radius: var(--r);
    font-size: 1rem;
    font-family: inherit;
  }
  .toolbar select {
    padding: 0.6rem 0.8rem;
    border: 1px solid var(--line-strong);
    border-radius: var(--r);
    font-size: 0.95rem;
    font-family: inherit;
    background: var(--surface);
  }
  .limpar { color: var(--ink-2); font-size: 0.9rem; }
  .acoes-linha { display: flex; gap: 0.4rem; align-items: center; }
  .acoes-linha form { margin: 0; }
  .nome-produto { color: var(--ink); font-weight: 700; text-decoration: none; }
  .nome-produto:hover { color: var(--accent-strong); }
  .ord {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    color: inherit;
    text-decoration: none;
    white-space: nowrap;
  }
  .ord:hover { color: var(--accent-strong); }
  .ord.ativo { color: var(--accent-strong); }
  .data { color: var(--ink-2); font-size: 0.9rem; white-space: nowrap; }
  .vazio a { color: var(--accent-strong); }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }
</style>
