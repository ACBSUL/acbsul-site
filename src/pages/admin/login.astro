---
// Tela de login do admin. Se já houver sessão, o middleware redireciona p/ /admin.
import AdminLayout from '../../layouts/AdminLayout.astro';

export const prerender = false;
---

<AdminLayout titulo="Entrar">
  <div class="palco">
    <div class="caixa">
      <p class="marca-login">
        <span class="logo">ACB Sul</span>
        <span class="tag-admin">Admin</span>
      </p>
      <h1>Painel do catálogo</h1>
      <p class="sub">Acesso restrito — somente administradores.</p>
      <form id="form-login" novalidate>
        <label class="campo">
          E-mail
          <input type="email" name="email" required autocomplete="username" autofocus />
        </label>
        <label class="campo">
          Senha
          <input type="password" name="senha" required autocomplete="current-password" />
        </label>
        <p id="erro" role="alert" tabindex="-1" hidden>
          E-mail ou senha incorretos. Confira e tente de novo.
        </p>
        <button class="botao entrar" type="submit">Entrar</button>
        <noscript>
          <p class="aviso-js">O login precisa de JavaScript habilitado no navegador.</p>
        </noscript>
      </form>
    </div>
  </div>
</AdminLayout>

<style>
  .palco { min-height: calc(100vh - 12rem); display: grid; place-items: center; }
  .caixa {
    width: min(400px, 100%);
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    box-shadow: var(--sombra);
    padding: clamp(1.5rem, 4vw, 2.25rem);
  }
  .marca-login { display: flex; align-items: baseline; gap: 0.5rem; margin-bottom: 1.5rem; }
  .marca-login .logo {
    font-family: 'Sora', var(--fonte);
    font-weight: 800;
    font-size: 1.15rem;
    color: var(--navy);
  }
  .marca-login .tag-admin {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #fff;
    background: var(--accent);
    border-radius: 5px;
    padding: 0.1rem 0.4rem;
  }
  h1 { font-size: 1.3rem; font-weight: 700; letter-spacing: -0.01em; }
  .sub { color: var(--ink-2); font-size: 0.9rem; margin: 0.25rem 0 1.5rem; }
  .campo { display: block; margin-bottom: 1rem; }
  #erro {
    color: var(--erro-ink);
    background: var(--erro-bg);
    border-radius: var(--r);
    padding: 0.6rem 0.85rem;
    font-size: 0.88rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }
  .entrar { width: 100%; }
  .entrar:disabled { opacity: 0.6; cursor: wait; }
  .aviso-js { margin-top: 0.75rem; color: var(--erro-ink); font-size: 0.85rem; }
</style>

<script>
  const form = document.getElementById('form-login') as HTMLFormElement;
  const erro = document.getElementById('erro') as HTMLParagraphElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    erro.hidden = true;
    const botao = form.querySelector('button')!;
    botao.disabled = true;
    botao.textContent = 'Entrando…';

    const dados = new FormData(form);
    const res = await fetch('/api/auth/sign-in/email', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email: dados.get('email'), password: dados.get('senha') }),
    }).catch(() => null);

    if (res?.ok) {
      location.href = '/admin';
    } else {
      erro.hidden = false;
      erro.focus();
      botao.disabled = false;
      botao.textContent = 'Entrar';
    }
  });
</script>
