---
// Admin → Editar categoria: WhatsApp por categoria (PRD §8 — o WhatsAppCTA
// do site lê esta config), introdução citável e SEO.
import { eq } from 'drizzle-orm';
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { db, tabelas } from '../../../db';
import { catIcons } from '../../../data/cat-icons';

export const prerender = false;

const id = Number(Astro.params.id);
if (!Number.isInteger(id)) return Astro.redirect('/admin/categorias');

if (Astro.request.method === 'POST') {
  const f = await Astro.request.formData();
  const texto = (k: string) => String(f.get(k) ?? '').trim();

  if (texto('_acao') === 'excluir') {
    // FK: produtos referenciam a categoria. Não dá pra excluir com produtos vinculados.
    const [comProduto] = await db
      .select({ id: tabelas.produtos.id })
      .from(tabelas.produtos)
      .where(eq(tabelas.produtos.categoriaId, id))
      .limit(1);
    if (comProduto) return Astro.redirect('/admin/categorias?erro=tem-produtos');
    await db.delete(tabelas.categorias).where(eq(tabelas.categorias.id, id));
    return Astro.redirect('/admin/categorias?ok=excluida');
  }

  await db
    .update(tabelas.categorias)
    .set({
      nome: texto('nome'),
      nomeCurto: texto('nomeCurto'),
      icone: texto('icone'),
      ordem: Number(texto('ordem')) || 0,
      introducao: texto('introducao') || null,
      seoTitle: texto('seoTitle') || null,
      seoDescription: texto('seoDescription') || null,
      // só dígitos, formato wa.me: DDI+DDD+número (ex.: 5551999998888)
      whatsappNumero: texto('whatsappNumero').replace(/\D/g, '') || null,
      whatsappMensagem: texto('whatsappMensagem') || null,
      ativa: f.get('ativa') === 'on',
      atualizadoEm: new Date(),
    })
    .where(eq(tabelas.categorias.id, id));
  return Astro.redirect(`/admin/categorias/${id}?ok=1`);
}

const [cat] = await db
  .select()
  .from(tabelas.categorias)
  .where(eq(tabelas.categorias.id, id));
if (!cat) return Astro.redirect('/admin/categorias');

const ok = Astro.url.searchParams.get('ok');
const salvo = ok === '1';
const criada = ok === 'criada';
const icones = Object.keys(catIcons);
---

<AdminLayout titulo={`Categoria · ${cat.nome}`}>
  <div class="acoes">
    <h1>{cat.nome}</h1>
    <a class="voltar" href="/admin/categorias">← Todas as categorias</a>
  </div>

  {criada && <p class="flash" role="status">Categoria criada — complete o WhatsApp, a introdução e o SEO aqui.</p>}
  {salvo && <p class="flash" role="status">Categoria salva. O site público já reflete a mudança.</p>}

  <form method="POST">
    <div class="editor-grid">
      <div>
        <div class="cartao-form">
          <h2>WhatsApp da categoria</h2>
          <p class="nota">
            Para onde vão os leads desta linha. Vazio = número geral da empresa.
          </p>
          <div class="campos">
            <label class="campo">
              Número (DDI+DDD+número, só dígitos)
              <input
                type="text"
                name="whatsappNumero"
                value={cat.whatsappNumero ?? ''}
                placeholder="5551999998888"
                inputmode="numeric"
              />
            </label>
            <label class="campo largo">
              Mensagem pré-preenchida (opcional)
              <input
                type="text"
                name="whatsappMensagem"
                value={cat.whatsappMensagem ?? ''}
                placeholder={`Olá! Quero um orçamento de ${cat.nome}.`}
              />
            </label>
          </div>
        </div>

        <div class="cartao-form">
          <h2>Identificação</h2>
          <div class="campos">
            <label class="campo">
              Nome completo <span class="req" aria-hidden="true">*</span>
              <input type="text" name="nome" value={cat.nome} required />
            </label>
            <label class="campo">
              Nome curto (chips/menus) <span class="req" aria-hidden="true">*</span>
              <input type="text" name="nomeCurto" value={cat.nomeCurto} required />
            </label>
            <label class="campo">
              Ordem de exibição
              <input type="number" name="ordem" value={cat.ordem} min="0" />
            </label>
            <div class="campo largo">
              <span class="rotulo-campo">Ícone</span>
              <div class="icon-picker" role="radiogroup" aria-label="Ícone da categoria">
                {icones.map((i) => (
                  <label class="icon-opt" title={i}>
                    <input type="radio" name="icone" value={i} checked={i === cat.icone} />
                    <span class="icon-box">
                      <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        set:html={catIcons[i]}
                      />
                      <span class="icon-nome">{i.replace(/-/g, ' ')}</span>
                    </span>
                  </label>
                ))}
              </div>
            </div>
          </div>
        </div>

        <div class="cartao-form">
          <h2>Conteúdo e SEO</h2>
          <div class="campos">
            <label class="campo largo">
              Introdução da categoria (parágrafo citável — aparece no catálogo)
              <textarea name="introducao">{cat.introducao ?? ''}</textarea>
            </label>
            <label class="campo largo">
              SEO Title
              <input
                type="text"
                name="seoTitle"
                value={cat.seoTitle ?? ''}
                maxlength="60"
                data-contador
              />
            </label>
            <label class="campo largo">
              Meta description
              <input
                type="text"
                name="seoDescription"
                value={cat.seoDescription ?? ''}
                maxlength="155"
                data-contador
              />
            </label>
          </div>
        </div>
      </div>

      <aside class="editor-lateral">
        <div class="cartao-form" style="margin-bottom:0">
          <h2>Visibilidade</h2>
          <label class="check">
            <input type="checkbox" name="ativa" checked={cat.ativa} />
            Categoria visível no site
          </label>
          <p class="nota" style="margin:0.75rem 0 0">
            Ocultar não apaga nada — os produtos continuam no banco.
          </p>
        </div>
      </aside>
    </div>

    <div class="barra-salvar">
      <button class="botao" type="submit">Salvar categoria</button>
      <span class="lembrete">As mudanças entram no ar imediatamente.</span>
    </div>
  </form>
</AdminLayout>
