---
import SiteLayout from '../layouts/SiteLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { empresa, entityBlockTexto } from '../data/empresa';

export const prerender = true;

// Página de Serviços (PRD §7 + Anexo 12.2.2). Conteúdo da página antiga reescrito
// com foco em explicação do serviço + conversão (WhatsApp por serviço e orçamento).
// H1 conforme PRD: "Assistência Técnica Especializada em Compressores no RS".

const title = 'Assistência Técnica de Compressores no RS | ACB Sul';
const description =
  'Assistência técnica autorizada Atlas Copco em Porto Alegre e todo o RS: manutenção preventiva e corretiva com peças originais e técnicos treinados na fábrica.';

const urlPagina = `${empresa.url}/servicos`;

// Bloco definicional citável (PRD Anexo 12.2.2 — usar literalmente).
const blocoDefinicional =
  'A manutenção preventiva de compressores consiste na troca programada de óleo, filtros e componentes conforme o número de horas trabalhadas indicado pelo fabricante. Na ACB Sul, o controle é feito por horímetro, prolongando a vida útil do equipamento e evitando paradas não planejadas na produção.';

// FAQ — primeira frase de cada resposta é afirmação direta (PRD Anexo 12.4 + serviço).
const faqItems = [
  {
    q: 'Com que frequência devo fazer a manutenção do compressor?',
    lead: 'A manutenção segue as horas trabalhadas indicadas pelo fabricante — geralmente a cada 250, 500 e 1000 horas para troca de óleo, filtros e componentes.',
    a: 'Na ACB Sul, o controle é feito por horímetro: avisamos quando a próxima revisão do seu equipamento se aproxima.',
    open: true,
  },
  {
    q: 'O que inclui um plano de manutenção preventiva?',
    lead: 'Um plano de manutenção preventiva inclui a troca programada de óleo, filtros e componentes conforme as horas de operação do equipamento.',
    a: 'O cronograma é definido por horímetro e executado com kits originais Atlas Copco de 250h, 500h e 1000h.',
    open: false,
  },
  {
    q: 'A assistência técnica atende em campo?',
    lead: 'Sim, a ACB Sul realiza manutenção preventiva e corretiva em campo e em oficina própria.',
    a: 'Técnicos treinados pelo fabricante atendem todo o Rio Grande do Sul e parte de Santa Catarina, com sede em Porto Alegre.',
    open: false,
  },
  {
    q: 'A ACB Sul usa peças originais Atlas Copco?',
    lead: 'Sim, todos os serviços utilizam peças de reposição originais Atlas Copco, garantindo desempenho e validade da garantia.',
    a: 'Mantemos estoque local de kits de revisão, filtros, óleos Paroil e fluidos Parcool, com condições especiais de entrega.',
    open: false,
  },
  {
    q: 'Quanto custa a manutenção de um compressor?',
    lead: 'O valor depende do modelo do equipamento, das horas de operação e do tipo de serviço necessário.',
    a: `Solicite uma avaliação sem compromisso pelo WhatsApp, pelo formulário de contato ou pelo telefone ${empresa.telefone} — respondemos em horário comercial.`,
    open: false,
  },
];

// Schemas: Service + FAQPage + BreadcrumbList (LocalBusiness é global no layout).
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Assistência técnica de compressores Atlas Copco',
  serviceType:
    'Assistência técnica, manutenção preventiva e corretiva de compressores de ar e equipamentos industriais',
  description,
  url: urlPagina,
  inLanguage: 'pt-BR',
  provider: {
    '@type': 'Organization',
    name: empresa.nome,
    url: empresa.url,
    brand: { '@type': 'Brand', name: 'Atlas Copco' },
  },
  areaServed: ['Rio Grande do Sul', 'Santa Catarina'],
};
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.lead + ' ' + f.a },
  })),
};
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Início', item: empresa.url },
    { '@type': 'ListItem', position: 2, name: 'Serviços', item: urlPagina },
  ],
};
---

<SiteLayout
  title={title}
  description={description}
  ogImage="/assets/empresa/oficina-assistencia-tecnica-atlas-copco-acbsul-porto-alegre.webp"
  page="servicos"
>
  <script
    type="application/ld+json"
    is:inline
    slot="head"
    set:html={JSON.stringify(serviceSchema)}
  />
  <script type="application/ld+json" is:inline slot="head" set:html={JSON.stringify(faqSchema)} />
  <script
    type="application/ld+json"
    is:inline
    slot="head"
    set:html={JSON.stringify(breadcrumbSchema)}
  />

  <SiteNav />

  <main>
    <!-- ============ PAGE HERO ============ -->
    <section class="page-hero">
      <div class="container">
        <nav class="breadcrumb" aria-label="Trilha">
          <a href="/">Início</a><span class="sep">/</span><span class="current">Serviços</span>
        </nav>
        <span class="eyebrow">Serviços · Assistência Autorizada Atlas Copco</span>
        <h1>Assistência Técnica Especializada em Compressores <span class="hl">no RS</span></h1>
        <p class="lead">
          A ACB Sul presta assistência técnica autorizada Atlas Copco em compressores de ar,
          geradores de energia e torres de iluminação — em oficina própria em Porto Alegre e em
          campo, em todo o Rio Grande do Sul e parte de Santa Catarina, com técnicos treinados na
          fábrica e peças originais.
        </p>
        <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:28px">
          <a
            class="btn btn-accent btn-lg"
            data-wa-msg="Olá! Preciso de assistência técnica para meu equipamento Atlas Copco."
            ><span class="ai"
              ><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"
                ><path d="M5 12h14M13 6l6 6-6 6"></path></svg
              ></span
            >Chamar a Assistência Técnica</a
          >
          <a class="btn btn-ghost-dark btn-lg" href="/#contato">Solicitar Orçamento</a>
        </div>
      </div>
    </section>

    <!-- ============ BLOCO DEFINICIONAL (citável — Anexo 12.2.2) ============ -->
    <section class="section tight entity-band" aria-label="Manutenção preventiva de compressores">
      <div class="container">
        <div class="entity-grid">
          <div class="entity-photo wide fade-up">
            <img
              src="/assets/empresa/oficina-assistencia-tecnica-atlas-copco-acbsul-porto-alegre.webp"
              alt="Oficina de assistência técnica da ACB Sul com compressores Atlas Copco em manutenção em Porto Alegre"
              width="820"
              height="458"
            />
            <div class="entity-badge">
              <b>RS·SC</b>
              <span>atendimento em campo</span>
            </div>
          </div>
          <div class="entity-block">
            <span class="eyebrow">O que é manutenção preventiva</span>
            <h2>Manutenção programada por <span class="hl">horímetro</span></h2>
            <p>{blocoDefinicional}</p>
            <ul class="entity-facts">
              <li>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                  ><circle cx="12" cy="12" r="9"></circle><path d="M12 7v5l3 3"></path></svg
                > Revisões a cada 250h, 500h e 1000h de operação
              </li>
              <li>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                  ><path d="M12 2 4 6v6c0 5 3.4 8.5 8 10 4.6-1.5 8-5 8-10V6l-8-4z"></path><path d="m9 12 2 2 4-4"></path></svg
                > Kits e peças de reposição originais Atlas Copco
              </li>
              <li>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                  ><path
                    d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"
                  ></path></svg
                > Técnicos capacitados e treinados na fábrica
              </li>
            </ul>
            <div style="margin-top:26px">
              <a
                class="btn btn-accent"
                data-wa-msg="Olá! Quero um plano de manutenção preventiva por horímetro para meu compressor."
                ><span class="ai"
                  ><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"
                    ><path d="M5 12h14M13 6l6 6-6 6"></path></svg
                  ></span
                >Montar meu plano preventivo</a
              >
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ GRADE DE SERVIÇOS ============ -->
    <section class="section" id="servicos" style="background:var(--bg-2)">
      <div class="container">
        <div class="sec-head">
          <span class="eyebrow">Nossa oferta de serviço</span>
          <h2>Tudo o que seu equipamento precisa, <span class="hl">em um só lugar</span></h2>
          <p>
            Da revisão programada à emergência em campo: cada serviço conecta você diretamente ao
            especialista certo da ACB Sul pelo WhatsApp.
          </p>
        </div>
        <div class="grid cols-3">
          <a
            class="svc-card fade-up"
            data-wa-msg="Olá! Quero um plano de manutenção preventiva para meu compressor Atlas Copco."
          >
            <span class="ico"
              ><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                ><circle cx="12" cy="12" r="3"></circle><path
                  d="M12 2v3M12 19v3M2 12h3M19 12h3M5 5l2 2M17 17l2 2M19 5l-2 2M7 17l-2 2"></path></svg
              ></span
            >
            <h3>Manutenção Preventiva</h3>
            <p>
              Plano de revisões por horímetro com troca de óleo, filtros e componentes nos
              intervalos do fabricante — para obter o melhor tempo de operação do compressor e
              evitar paradas não planejadas.
            </p>
            <span class="more"
              >Montar plano preventivo <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"
                ><path d="M5 12h14M13 6l6 6-6 6"></path></svg
              ></span
            >
          </a>
          <a
            class="svc-card fade-up"
            data-wa-msg="Olá! Meu equipamento Atlas Copco apresentou um problema e preciso de manutenção corretiva."
          >
            <span class="ico"
              ><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                ><path
                  d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"
                ></path></svg
              ></span
            >
            <h3>Manutenção Corretiva</h3>
            <p>
              Diagnóstico e reparo de falhas em oficina própria em Porto Alegre ou no local da sua
              operação, com agilidade para reduzir ao máximo o tempo de máquina parada.
            </p>
            <span class="more"
              >Chamar a assistência <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"
                ><path d="M5 12h14M13 6l6 6-6 6"></path></svg
              ></span
            >
          </a>
          <a
            class="svc-card fade-up"
            data-wa-msg="Olá! Preciso de atendimento técnico em campo (RS/SC) para equipamento Atlas Copco."
          >
            <span class="ico"
              ><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                ><circle cx="7" cy="18" r="2"></circle><circle cx="17" cy="18" r="2"></circle><path
                  d="M5 18H3V8h13l4 5v5h-2M9 18h6"></path></svg
              ></span
            >
            <h3>Atendimento em Campo</h3>
            <p>
              Equipe técnica com frota própria atende sua planta ou obra em todo o Rio Grande do
              Sul e parte de Santa Catarina — instalação, start-up, revisão e emergências.
            </p>
            <span class="more"
              >Solicitar visita técnica <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"
                ><path d="M5 12h14M13 6l6 6-6 6"></path></svg
              ></span
            >
          </a>
          <a class="svc-card fade-up" href="/produtos#pecas">
            <span class="ico"
              ><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                ><path d="M12 2 4 6v6c0 5 3.4 8.5 8 10 4.6-1.5 8-5 8-10V6l-8-4z"></path><path d="m9 12 2 2 4-4"></path></svg
              ></span
            >
            <h3>Peças e Lubrificantes Originais</h3>
            <p>
              Estoque local com toda a linha de reposição Atlas Copco: kits de revisão 250h / 500h
              / 1000h, filtros, óleos Paroil e fluidos Parcool — com garantia de fábrica.
            </p>
            <span class="more"
              >Ver peças no catálogo <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"
                ><path d="M5 12h14M13 6l6 6-6 6"></path></svg
              ></span
            >
          </a>
          <a
            class="svc-card fade-up"
            data-wa-msg="Olá! Quero saber mais sobre atualizações e modernização do meu compressor Atlas Copco."
          >
            <span class="ico"
              ><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                ><path d="M13 2 4 14h7l-1 8 9-12h-7l1-8z"></path></svg
              ></span
            >
            <h3>Atualizações do Compressor</h3>
            <p>
              Modernização de equipamentos em operação: atualização de componentes e controladores
              para recuperar eficiência energética e estender a vida útil do seu compressor.
            </p>
            <span class="more"
              >Avaliar meu equipamento <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"
                ><path d="M5 12h14M13 6l6 6-6 6"></path></svg
              ></span
            >
          </a>
          <a
            class="svc-card fade-up"
            data-wa-msg="Olá! Quero saber mais sobre o monitoramento remoto FleetLink da Atlas Copco."
          >
            <span class="ico"
              ><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                ><path d="M5 12.55a11 11 0 0 1 14.08 0M8.53 16.11a6 6 0 0 1 6.95 0"></path><circle cx="12" cy="20" r="1"></circle></svg
              ></span
            >
            <h3>Monitoramento FleetLink</h3>
            <p>
              Telemetria Atlas Copco para acompanhar à distância horas de operação, localização e
              alertas da sua frota de compressores e geradores — manutenção no momento certo.
            </p>
            <span class="more"
              >Conhecer o FleetLink <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"
                ><path d="M5 12h14M13 6l6 6-6 6"></path></svg
              ></span
            >
          </a>
        </div>
      </div>
    </section>

    <!-- ============ EQUIPAMENTOS ATENDIDOS ============ -->
    <section class="section" aria-label="Equipamentos atendidos">
      <div class="container">
        <div class="split">
          <div class="cap-img fade-up">
            <img
              src="/assets/products/compressor-portatil-xas-300.png"
              alt="Compressor portátil Atlas Copco XAS atendido pela assistência técnica da ACB Sul no RS"
              loading="lazy"
              decoding="async"
              style="width:100%;height:100%;object-fit:cover"
            />
            <div class="badge">
              <img src="/assets/logo-acbsul-light.svg" alt="ACB Sul Compressores" />
            </div>
          </div>
          <div>
            <span class="eyebrow">Equipamentos atendidos</span>
            <h2 style="margin-top:18px">
              Especialistas na linha <span class="hl">Power Technique Atlas Copco</span>
            </h2>
            <p class="lead">
              Atendemos máquinas pneumáticas, soluções de energia portátil e equipamentos para
              construção civil e indústria — de compressores estacionários diesel e elétricos a
              rompedores e perfuratrizes.
            </p>
            <ul class="cap-checks">
              <li>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"
                  ><path d="M20 6 9 17l-5-5"></path></svg
                > Compressores diesel estacionários
              </li>
              <li>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"
                  ><path d="M20 6 9 17l-5-5"></path></svg
                > Compressores elétricos
              </li>
              <li>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"
                  ><path d="M20 6 9 17l-5-5"></path></svg
                > Compressores portáteis
              </li>
              <li>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"
                  ><path d="M20 6 9 17l-5-5"></path></svg
                > Geradores de energia
              </li>
              <li>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"
                  ><path d="M20 6 9 17l-5-5"></path></svg
                > Torres de iluminação
              </li>
              <li>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"
                  ><path d="M20 6 9 17l-5-5"></path></svg
                > Bombas e motobombas
              </li>
              <li>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"
                  ><path d="M20 6 9 17l-5-5"></path></svg
                > Rompedores e perfuratrizes
              </li>
              <li>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"
                  ><path d="M20 6 9 17l-5-5"></path></svg
                > Filtros e lubrificantes
              </li>
            </ul>
            <a class="btn btn-accent btn-lg" href="/#contato"
              ><span class="ai"
                ><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"
                  ><path d="M5 12h14M13 6l6 6-6 6"></path></svg
                ></span
              >Solicitar Orçamento Técnico</a
            >
          </div>
        </div>
      </div>
    </section>

    <!-- ============ COMO FUNCIONA ============ -->
    <section class="section tight" style="background:var(--bg-2)" aria-label="Como funciona o atendimento">
      <div class="container">
        <div class="sec-head">
          <span class="eyebrow">Como funciona</span>
          <h2>Do primeiro contato à máquina <span class="hl">rodando de novo</span></h2>
          <p>
            Processo direto, sem burocracia — você fala com gente que entende do seu equipamento.
          </p>
        </div>
        <div class="grid cols-4">
          <div class="proc-card fade-up">
            <div class="proc-num">1</div><h3>Contato e diagnóstico</h3><p>
              Você descreve o equipamento e o problema (ou as horas de operação) pelo WhatsApp,
              formulário ou telefone.
            </p>
          </div>
          <div class="proc-card fade-up">
            <div class="proc-num">2</div><h3>Orçamento claro</h3><p>
              Enviamos proposta com serviços, peças originais necessárias e prazo — sem surpresas.
            </p>
          </div>
          <div class="proc-card fade-up">
            <div class="proc-num">3</div><h3>Execução do serviço</h3><p>
              Atendimento em campo ou em oficina própria, por técnicos treinados na fábrica.
            </p>
          </div>
          <div class="proc-card fade-up">
            <div class="proc-num">4</div><h3>Acompanhamento</h3><p>
              Controle por horímetro e aviso da próxima revisão para sua operação não parar.
            </p>
          </div>
        </div>
        <div class="center-cta">
          <a
            class="btn btn-accent btn-lg"
            data-wa-msg="Olá! Quero falar com a equipe técnica da ACB Sul sobre meu equipamento."
            ><span class="ai"
              ><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"
                ><path d="M5 12h14M13 6l6 6-6 6"></path></svg
              ></span
            >Falar com a equipe técnica</a
          >
        </div>
      </div>
    </section>

    <!-- ============ CTA BAND ============ -->
    <section class="section tight">
      <div class="container">
        <div class="cta-band">
          <div>
            <h2>Compressor parado é <span class="hl">prejuízo por hora</span></h2>
            <p>
              Fale agora com a assistência técnica autorizada Atlas Copco no RS e receba o
              atendimento certo — preventiva, corretiva ou peças originais.
            </p>
          </div>
          <div class="acts">
            <a
              class="btn btn-accent btn-lg"
              data-wa-msg="Olá! Preciso de assistência técnica para meu equipamento Atlas Copco."
              ><span class="ai"
                ><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"
                  ><path d="M5 12h14M13 6l6 6-6 6"></path></svg
                ></span
              >Chamar a Assistência</a
            >
            <a class="btn btn-ghost-dark btn-lg" href="/#contato">Solicitar Orçamento</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ FAQ ============ -->
    <section class="section" id="faq" aria-label="Dúvidas frequentes sobre assistência técnica">
      <div class="container">
        <div class="sec-head">
          <span class="eyebrow">FAQ</span>
          <h2>Dúvidas frequentes sobre <span class="hl">manutenção</span></h2>
          <p>O essencial sobre revisões, peças originais e atendimento em campo.</p>
        </div>
        <div class="faq-list">
          {
            faqItems.map((item) => (
              <div class={item.open ? 'faq-item open' : 'faq-item'}>
                <button class="faq-q">
                  {item.q}
                  <span class="chev">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                      <path d="m6 9 6 6 6-6" />
                    </svg>
                  </span>
                </button>
                <div class="faq-a">
                  <div class="inner">
                    <b>{item.lead}</b> {item.a}
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

