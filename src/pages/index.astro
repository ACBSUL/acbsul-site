---
import SiteLayout from '../layouts/SiteLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { empresa, entityBlockTexto } from '../data/empresa';

export const prerender = true;

const title =
  'ACB Sul Compressores | Atlas Copco no RS — Ar Comprimido e Energia para a Indústria';
const description =
  'Distribuidor autorizado Atlas Copco no RS. Compressores, geradores, peças originais, locação e assistência técnica especializada em Porto Alegre. 40+ anos.';

// FAQ — primeira frase de cada resposta é afirmação direta (citável). Alimenta markup + FAQPage.
const faqItems = [
  {
    q: 'A ACB Sul é distribuidora autorizada Atlas Copco?',
    lead: 'Sim. A ACB Sul é distribuidora autorizada Atlas Copco no Rio Grande do Sul.',
    a: 'Isso garante acesso à linha completa de produtos, peças originais com garantia de fábrica e suporte técnico oficial da marca.',
    open: true,
  },
  {
    q: 'Vocês fazem assistência técnica em campo?',
    lead: '',
    a: 'Sim. Nossa equipe técnica realiza manutenção preventiva, corretiva e instalação em campo em todo o RS e SC, com controle por horímetro e peças originais.',
    open: false,
  },
  {
    q: 'É possível alugar compressores e geradores?',
    lead: '',
    a: 'Sim. Oferecemos locação de compressores, geradores e torres de iluminação com pronta-entrega, equipamentos revisados e contratos flexíveis, sem necessidade de investimento de capital.',
    open: false,
  },
  {
    q: 'Quais regiões a ACB Sul atende?',
    lead: '',
    a: 'Atendemos indústrias e obras em todo o Rio Grande do Sul e Santa Catarina, com sede em Porto Alegre/RS.',
    open: false,
  },
  {
    q: 'Como solicito um orçamento?',
    lead: '',
    a: `Você pode solicitar pelo formulário desta página, pelo WhatsApp da linha desejada ou pelo telefone ${empresa.telefone}, em horário comercial.`,
    open: false,
  },
];

const testimonials = [
  {
    quote:
      'A ACB Sul nos passou segurança desde o primeiro contato. O dimensionamento técnico e a entrega no prazo fizeram diferença na nossa parada de fábrica.',
    name: 'Ricardo Santos',
    role: 'Gerente Industrial · Indústria RS',
  },
  {
    quote:
      'Assistência técnica rápida e peças originais sempre disponíveis. Reduziu bastante nosso tempo de parada de compressor.',
    name: 'Marcos Pereira',
    role: 'Manutenção · Metalúrgica POA',
  },
  {
    quote:
      'Alugamos geradores em pronta-entrega para uma obra e o suporte foi impecável do início ao fim.',
    name: 'Carla Lemos',
    role: 'Engenheira de Obras · Construtora SC',
  },
  {
    quote:
      'Equipe que entende de ar comprimido de verdade. Indicaram a solução certa para a nossa vazão.',
    name: 'André Becker',
    role: 'Diretor · Frigorífico RS',
  },
  {
    quote:
      'Parceria de anos. Confiança e atendimento técnico que a gente não encontra em qualquer fornecedor.',
    name: 'Juliana Rocha',
    role: 'Suprimentos · Indústria Química',
  },
];

// Schema GEO (Organization + WebSite + FAQPage). LocalBusiness é global no layout.
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: empresa.nome,
  url: empresa.url,
  description: `${empresa.posicionamento}, com ${empresa.longevidade} de atuação.`,
  brand: { '@type': 'Brand', name: 'Atlas Copco' },
  areaServed: ['Rio Grande do Sul', 'Santa Catarina'],
};
const webSiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: empresa.nome,
  url: empresa.url,
  inLanguage: 'pt-BR',
};
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: (f.lead ? f.lead + ' ' : '') + f.a,
    },
  })),
};
---

<SiteLayout title={title} description={description}>
  <script
    type="application/ld+json"
    is:inline
    slot="head"
    set:html={JSON.stringify(orgSchema)}
  />
  <script
    type="application/ld+json"
    is:inline
    slot="head"
    set:html={JSON.stringify(webSiteSchema)}
  />
  <script type="application/ld+json" is:inline slot="head" set:html={JSON.stringify(faqSchema)} />

  <SiteNav />

  <!-- ============ HERO ============ -->
  <header class="hero" data-screen-label="Hero">
    <div class="hero-photo">
      <img
        class="hero-img"
        src="/assets/hero-obra-qas.jpg"
        alt="Gerador Atlas Copco QAS em obra, com técnico ao lado"
        fetchpriority="high"
      />
      <div class="hero-overlay"></div>
    </div>
    <div class="container">
      <div class="hero-copy">
        <span class="eyebrow">Distribuidor Autorizado Atlas Copco</span>
        <h1>Compressores Industriais e Assistência Técnica <span class="hl">Atlas Copco no RS</span></h1>
        <p class="tagline">Ar comprimido e energia para <span class="hl">grandes operações</span>.</p>
        <p class="lead">
          A ACB Sul é distribuidora autorizada Atlas Copco no Rio Grande do Sul há mais de 40 anos.
          Com sede em Porto Alegre, fornece compressores, geradores, peças originais e assistência
          técnica para a indústria do RS e de Santa Catarina.
        </p>
        <div class="hero-actions">
          <a class="btn btn-accent btn-lg" href="#contato"
            ><span class="ai"
              ><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"
                ><path d="M5 12h14M13 6l6 6-6 6"></path></svg
              ></span
            >Solicitar Orçamento Técnico</a
          >
          <a class="btn btn-ghost-dark btn-lg" href="/produtos">Ver Catálogo</a>
        </div>
      </div>
    </div>
  </header>

  <!-- ============ MARQUEE ============ -->
  <div class="marquee" aria-hidden="true">
    <div class="track">
      <span>Peças Originais Atlas Copco</span><span>Assistência Técnica RS &amp; SC</span><span
        >40+ Anos de Mercado</span
      ><span>Venda &amp; Locação</span><span>Distribuidor Autorizado</span>
      <span>Peças Originais Atlas Copco</span><span>Assistência Técnica RS &amp; SC</span><span
        >40+ Anos de Mercado</span
      ><span>Venda &amp; Locação</span><span>Distribuidor Autorizado</span>
    </div>
  </div>

  <!-- ============ ENTITYBLOCK (maior impacto GEO) ============ -->
  <section class="section tight entity-band" id="sobre" aria-label="Sobre a ACB Sul">
    <div class="container">
      <div class="entity-grid">
        <div class="entity-photo fade-up">
          <img
            src="/assets/hero-obra-qas.jpg" loading="lazy" decoding="async"
            alt="Técnico ao lado de gerador Atlas Copco QAS em obra atendida pela ACB Sul"
          />
          <div class="entity-badge">
            <b>40+</b>
            <span>anos de mercado</span>
          </div>
        </div>
        <div class="entity-block">
          <span class="eyebrow">A ACB Sul</span>
          <h2>Quatro décadas de engenharia em <span class="hl">ar comprimido e energia</span></h2>
          <p>{entityBlockTexto}</p>
          <ul class="entity-facts">
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                ><path d="M12 2 4 6v6c0 5 3.4 8.5 8 10 4.6-1.5 8-5 8-10V6l-8-4z"></path><path d="m9 12 2 2 4-4"></path></svg
              > Distribuidor autorizado Atlas Copco
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                ><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg
              > Sede em Porto Alegre, no Rio Grande do Sul
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                ><circle cx="7" cy="18" r="2"></circle><circle cx="17" cy="18" r="2"></circle><path d="M5 18H3V8h13l4 5v5h-2M9 18h6"></path></svg
              > Atendimento em campo em todo o RS e SC
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ LINHAS DE PRODUTO ============ -->
  <section class="section" id="linhas">
    <div class="container">
      <div class="sec-head">
        <span class="eyebrow">Linhas de Produto</span>
        <h2>Soluções completas em <span class="hl">ar comprimido e energia</span></h2>
        <p>
          A ACB Sul atende operações que exigem disponibilidade, eficiência e suporte técnico — do
          compressor de parafuso ao gerador Stage V.
        </p>
      </div>

      <div class="grid cols-3">
        <article class="seg-card fade-up">
          <div class="seg-media">
            <img
              src="/assets/products/compressor-parafuso-ga-vsd.png" loading="lazy" decoding="async"
              alt="Compressores de parafuso Atlas Copco da linha GA com tecnologia VSD"
            />
            <span class="seg-icon"
              ><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                ><circle cx="12" cy="12" r="3"></circle><path
                  d="M12 2v4M12 18v4M22 12h-4M6 12H2M19 5l-3 3M8 16l-3 3M19 19l-3-3M8 8 5 5"></path></svg
              ></span
            >
          </div>
          <div class="seg-body">
            <h3>Compressores de Parafuso</h3>
            <p>Linha GA com tecnologia VSD⁺ para ar comprimido contínuo, eficiente e econômico.</p>
            <div class="foot">
              <a
                class="link-arrow"
                data-wa-msg="Olá! Quero falar com um especialista em compressores de parafuso Atlas Copco."
                >Falar com especialista <span class="dot"
                  ><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"
                    ><path d="M5 12h14M13 6l6 6-6 6"></path></svg
                  ></span
                ></a
              >
            </div>
          </div>
        </article>

        <article class="seg-card fade-up">
          <div class="seg-media ph">
            <span class="ph-label">Compressor de Pistão</span>
            <span class="seg-icon"
              ><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                ><rect x="4" y="9" width="16" height="11" rx="1"></rect><path d="M9 9V5h6v4M12 13v3"
                ></path></svg
              ></span
            >
          </div>
          <div class="seg-body">
            <h3>Compressores de Pistão</h3>
            <p>Robustos e versáteis para oficinas, pequenas indústrias e uso intermitente.</p>
            <div class="foot">
              <a
                class="link-arrow"
                data-wa-msg="Olá! Quero falar com um especialista em compressores de pistão Atlas Copco."
                >Falar com especialista <span class="dot"
                  ><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"
                    ><path d="M5 12h14M13 6l6 6-6 6"></path></svg
                  ></span
                ></a
              >
            </div>
          </div>
        </article>

        <article class="seg-card fade-up">
          <a href="/produtos#geradores-de-energia" class="seg-media"
            ><img
              src="/assets/products/gerador-qas-210.jpg" loading="lazy" decoding="async"
              alt="Gerador de energia Atlas Copco QAS 210"
            />
            <span class="seg-icon"
              ><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                ><path d="M13 2 4 14h7l-1 8 9-12h-7l1-8z"></path></svg
              ></span
            ></a
          >
          <div class="seg-body">
            <h3>Geradores de Energia</h3>
            <p>Geradores Stage V de alta eficiência para obras, eventos e backup industrial.</p>
            <div class="foot">
              <a class="link-arrow" href="/produtos#geradores-de-energia"
                >Ver linha <span class="dot"
                  ><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"
                    ><path d="M5 12h14M13 6l6 6-6 6"></path></svg
                  ></span
                ></a
              >
            </div>
          </div>
        </article>

        <article class="seg-card fade-up">
          <div class="seg-media">
            <img
              src="/assets/products/compressor-portatil-xas-300.png" loading="lazy" decoding="async"
              alt="Compressor portátil Atlas Copco XAS 300"
            />
            <span class="seg-icon"
              ><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                ><circle cx="7" cy="18" r="2"></circle><circle cx="17" cy="18" r="2"></circle><path
                  d="M5 18H3V8h13l4 5v5h-2M9 18h6"></path></svg
              ></span
            >
          </div>
          <div class="seg-body">
            <h3>Compressores Portáteis</h3>
            <p>Equipamentos móveis Stage V para construção civil, mineração e serviços de campo.</p>
            <div class="foot">
              <a
                class="link-arrow"
                data-wa-msg="Olá! Quero falar com um especialista em compressores portáteis Atlas Copco."
                >Falar com especialista <span class="dot"
                  ><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"
                    ><path d="M5 12h14M13 6l6 6-6 6"></path></svg
                  ></span
                ></a
              >
            </div>
          </div>
        </article>

        <article class="seg-card fade-up">
          <div class="seg-media ph">
            <span class="ph-label">Tratamento de Ar</span>
            <span class="seg-icon"
              ><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                ><path d="M9.5 5a2.5 2.5 0 1 1 2 4H2M13 19a2 2 0 1 0 2-3H2M17 8a2.5 2.5 0 1 1 2 4H10"
                ></path></svg
              ></span
            >
          </div>
          <div class="seg-body">
            <h3>Tratamento de Ar</h3>
            <p>
              Secadores, filtros e purificadores para garantir ar comprimido limpo, seco e de
              qualidade.
            </p>
            <div class="foot">
              <a
                class="link-arrow"
                data-wa-msg="Olá! Quero falar com um especialista em tratamento de ar comprimido Atlas Copco."
                >Falar com especialista <span class="dot"
                  ><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"
                    ><path d="M5 12h14M13 6l6 6-6 6"></path></svg
                  ></span
                ></a
              >
            </div>
          </div>
        </article>

        <article class="seg-card fade-up">
          <div class="seg-media">
            <img
              src="/assets/products/bomba-vacuo-dzs150.jpg" loading="lazy" decoding="async"
              alt="Bomba de vácuo Atlas Copco DZS 150"
            />
            <span class="seg-icon"
              ><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                ><circle cx="12" cy="12" r="9"></circle><path d="M12 12 7 7M12 3v3M12 18v3"></path></svg
              ></span
            >
          </div>
          <div class="seg-body">
            <h3>Bombas de Vácuo</h3>
            <p>
              Tecnologia de vácuo industrial para embalagem, processos químicos e manuseio de
              materiais.
            </p>
            <div class="foot">
              <a
                class="link-arrow"
                data-wa-msg="Olá! Quero falar com um especialista em bombas de vácuo Atlas Copco."
                >Falar com especialista <span class="dot"
                  ><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"
                    ><path d="M5 12h14M13 6l6 6-6 6"></path></svg
                  ></span
                ></a
              >
            </div>
          </div>
        </article>
      </div>

      <div class="center-cta">
        <a class="btn btn-accent btn-lg" href="/produtos"
          ><span class="ai"
            ><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"
              ><path d="M5 12h14M13 6l6 6-6 6"></path></svg
            ></span
          >Ver catálogo completo</a
        >
      </div>
    </div>
  </section>

  <!-- ============ SERVIÇOS ============ -->
  <section class="section" id="servicos" style="background:var(--bg-2)">
    <div class="container">
      <div class="sec-head">
        <span class="eyebrow">Serviços</span>
        <h2>Muito além da venda: <span class="hl">suporte técnico de ponta a ponta</span></h2>
        <p>
          A ACB Sul é assistência autorizada Atlas Copco no RS — manutenção, peças originais e
          locação para manter sua operação disponível.
        </p>
      </div>
      <div class="grid cols-4">
        <!-- destinos provisórios (WhatsApp/catálogo) até /servicos e /locacao existirem -->
        <a
          class="svc-card fade-up"
          data-wa-msg="Olá! Preciso de assistência técnica para meu equipamento Atlas Copco."
        >
          <span class="ico"
            ><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
              ><path
                d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"
              ></path></svg
            ></span
          >
          <h3>Assistência Técnica</h3>
          <p>Atendimento autorizado em campo e em oficina, com técnicos especializados no RS e SC.</p>
          <span class="more"
            >Falar com especialista <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"
              ><path d="M5 12h14M13 6l6 6-6 6"></path></svg
            ></span
          >
        </a>
        <a
          class="svc-card fade-up"
          data-wa-msg="Olá! Quero um plano de manutenção preventiva por horímetro para meu compressor."
        >
          <span class="ico"
            ><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
              ><circle cx="12" cy="12" r="3"></circle><path
                d="M12 2v3M12 19v3M2 12h3M19 12h3M5 5l2 2M17 17l2 2M19 5l-2 2M7 17l-2 2"></path></svg
            ></span
          >
          <h3>Manutenção Preventiva</h3>
          <p>Planos por horímetro com troca de óleo, filtros e componentes para evitar paradas.</p>
          <span class="more"
            >Falar com especialista <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"
              ><path d="M5 12h14M13 6l6 6-6 6"></path></svg
            ></span
          >
        </a>
        <a class="svc-card fade-up" href="/produtos#pecas">
          <span class="ico"
            ><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
              ><path
                d="M12 2 4 6v6c0 5 3.4 8.5 8 10 4.6-1.5 8-5 8-10V6l-8-4z"></path><path d="m9 12 2 2 4-4"
              ></path></svg
            ></span
          >
          <h3>Peças Originais</h3>
          <p>Kits de revisão 250h / 500h / 1000h e peças genuínas Atlas Copco com garantia.</p>
          <span class="more"
            >Ver no catálogo <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"
              ><path d="M5 12h14M13 6l6 6-6 6"></path></svg
            ></span
          >
        </a>
        <a
          class="svc-card fade-up"
          data-wa-msg="Olá! Quero informações sobre locação de compressores, geradores ou torres de iluminação."
        >
          <span class="ico"
            ><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
              ><circle cx="7" cy="18" r="2"></circle><circle cx="17" cy="18" r="2"></circle><path
                d="M5 18H3V8h13l4 5v5h-2M9 18h6"></path></svg
            ></span
          >
          <h3>Locação de Equipamentos</h3>
          <p>Compressores, geradores e torres de iluminação revisados, com pronta-entrega.</p>
          <span class="more"
            >Falar com especialista <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"
              ><path d="M5 12h14M13 6l6 6-6 6"></path></svg
            ></span
          >
        </a>
      </div>
    </div>
  </section>

  <!-- ============ DIFERENCIAIS ============ -->
  <section class="section" id="diferenciais">
    <div class="container">
      <div class="split">
        <div>
          <span class="eyebrow">Diferenciais</span>
          <h2 style="margin-top:18px">
            Por que a ACB Sul é a escolha da <span class="hl">indústria gaúcha</span>
          </h2>
          <p class="lead">
            Unimos a tecnologia da maior fabricante mundial de compressores com atendimento técnico
            local, ágil e de confiança. É essa combinação que garante disponibilidade e
            previsibilidade para a sua operação.
          </p>
          <a class="btn btn-accent btn-lg" href="#contato"
            ><span class="ai"
              ><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"
                ><path d="M5 12h14M13 6l6 6-6 6"></path></svg
              ></span
            >Solicitar Orçamento Técnico</a
          >
        </div>
        <div class="feat-grid">
          <div class="feat fade-up">
            <span class="ico"
              ><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                ><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg
              ></span
            ><h3>Distribuidor Atlas Copco</h3><p>
              Linha completa, garantia de fábrica e suporte oficial da marca.
            </p>
          </div>
          <div class="feat fade-up">
            <span class="ico"
              ><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                ><circle cx="12" cy="12" r="3"></circle><path d="M12 2v3M12 19v3M2 12h3M19 12h3"
                ></path></svg
