---
// Admin → Editar produto. Princípio do modelo aprovado: campos atômicos +
// composição por regra — os derivados (nome, H1, SEO, alt, WhatsApp) são
// mostrados em preview; overrides são opcionais. Upload → Supabase Storage.
import { asc, eq } from 'drizzle-orm';
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { db, tabelas } from '../../../db';
import {
  type Produto,
  nomeProduto,
  h1Produto,
  altImagem,
  seoTitleProduto,
  seoDescriptionProduto,
  waMsgProduto,
} from '../../../data/produtos';
import {
  carregarCategorias,
  parseChips,
  parseSpecs,
  parseParagrafos,
  slugify,
} from '../../../lib/catalogo';
import { enviarImagemProduto, validarImagem } from '../../../lib/storage';

export const prerender = false;

const id = Number(Astro.params.id);
if (!Number.isInteger(id)) return Astro.redirect('/admin/produtos');

const t = tabelas.produtos;
let erro = '';

if (Astro.request.method === 'POST') {
  const f = await Astro.request.formData();
  const texto = (k: string) => String(f.get(k) ?? '').trim();
  const acao = texto('_acao');

  if (acao === 'excluir') {
    await db.delete(t).where(eq(t.id, id)); // imagens/specs caem em cascata
    return Astro.redirect('/admin/produtos?ok=excluido');
  }

  if (acao === 'salvar') {
    const slug = slugify(texto('slug'));
    await db
      .update(t)
      .set({
        codigo: texto('codigo'),
        etiqueta: texto('etiqueta') || null,
        tipo: texto('tipo'),
        categoriaId: Number(texto('categoriaId')),
        marca: texto('marca') || null,
        nome: texto('nome') || null,
        slug: slug || undefined,
        specsChips: parseChips(texto('specsChips')),
        destaque: f.get('destaque') === 'on',
        publicado: f.get('publicado') === 'on',
        pitch: texto('pitch') || null,
        descricao: parseParagrafos(texto('descricao')).length
          ? parseParagrafos(texto('descricao'))
          : null,
        seoTitle: texto('seoTitle') || null,
        seoDescription: texto('seoDescription') || null,
        atualizadoEm: new Date(),
      })
      .where(eq(t.id, id));

    // especificações: substituição completa (textarea "Rótulo | Valor")
    await db.delete(tabelas.produtoSpecs).where(eq(tabelas.produtoSpecs.produtoId, id));
    const specs = parseSpecs(texto('especificacoes'));
    if (specs.length) {
      await db.insert(tabelas.produtoSpecs).values(
        specs.map((s, i) => ({ produtoId: id, rotulo: s.rotulo, valor: s.valor, ordem: i })),
      );
    }
    return Astro.redirect(`/admin/produtos/${id}?ok=1`);
  }

  if (acao === 'img-add') {
    const arquivo = f.get('arquivo');
    if (arquivo instanceof File && arquivo.size > 0) {
      const problema = validarImagem(arquivo);
      if (problema) {
        erro = problema;
      } else {
        const ext = arquivo.name.split('.').pop()?.toLowerCase() ?? 'jpg';
        const base = `${slugify(arquivo.name.replace(/\.[^.]+$/, '')) || 'imagem'}.${ext}`;
        const url = await enviarImagemProduto(base, await arquivo.arrayBuffer(), arquivo.type);
        const existentes = await db
          .select({ id: tabelas.produtoImagens.id })
          .from(tabelas.produtoImagens)
          .where(eq(tabelas.produtoImagens.produtoId, id));
        await db.insert(tabelas.produtoImagens).values({
          produtoId: id,
          src: url,
          alt: texto('alt') || null,
          principal: existentes.length === 0,
          ordem: existentes.length,
        });
        return Astro.redirect(`/admin/produtos/${id}?ok=img`);
      }
    } else {
      erro = 'Selecione um arquivo de imagem.';
    }
  }

  if (acao === 'img-remover') {
    await db
      .delete(tabelas.produtoImagens)
      .where(eq(tabelas.produtoImagens.id, Number(texto('imgId'))));
    return Astro.redirect(`/admin/produtos/${id}?ok=img`);
  }

  if (acao === 'img-principal') {
    await db
      .update(tabelas.produtoImagens)
      .set({ principal: false })
      .where(eq(tabelas.produtoImagens.produtoId, id));
    await db
      .update(tabelas.produtoImagens)
      .set({ principal: true })
      .where(eq(tabelas.produtoImagens.id, Number(texto('imgId'))));
    return Astro.redirect(`/admin/produtos/${id}?ok=img`);
  }

  if (acao === 'img-alt') {
    await db
      .update(tabelas.produtoImagens)
      .set({ alt: texto('alt') || null })
      .where(eq(tabelas.produtoImagens.id, Number(texto('imgId'))));
    return Astro.redirect(`/admin/produtos/${id}?ok=img`);
  }
}

const [linha] = await db.select().from(t).where(eq(t.id, id));
if (!linha) return Astro.redirect('/admin/produtos');

const categorias = await carregarCategorias();
const imagens = await db
  .select()
  .from(tabelas.produtoImagens)
  .where(eq(tabelas.produtoImagens.produtoId, id))
  .orderBy(asc(tabelas.produtoImagens.ordem));
const specs = await db
  .select()
  .from(tabelas.produtoSpecs)
  .where(eq(tabelas.produtoSpecs.produtoId, id))
  .orderBy(asc(tabelas.produtoSpecs.ordem));

const categoria = categorias.find((c) => c.id === linha.categoriaId);

// pseudo-Produto para o preview dos derivados (mesmas regras do site)
const pseudo: Produto = {
  slug: linha.slug,
  codigo: linha.codigo,
  etiqueta: linha.etiqueta ?? undefined,
  tipo: linha.tipo,
  categoria: (categoria?.slug ?? '') as Produto['categoria'],
  marca: linha.marca ?? undefined,
  nome: linha.nome ?? undefined,
  specsChips: linha.specsChips ?? [],
  imagens: [],
  seoTitle: linha.seoTitle ?? undefined,
  seoDescription: linha.seoDescription ?? undefined,
};

const tituloDerivado = seoTitleProduto(pseudo);
const metaDerivada = seoDescriptionProduto(pseudo);
const ok = Astro.url.searchParams.get('ok');

const especificacoesTexto = specs.map((s) => `${s.rotulo} | ${s.valor}`).join('\n');
const descricaoTexto = (linha.descricao ?? []).join('\n\n');

const temPitch = Boolean(linha.pitch);
const temDescricao = Boolean(linha.descricao?.length);
const temSpecs = specs.length > 0;
const temImagem = imagens.length > 0;
const completa = temPitch && temDescricao && temSpecs;
const urlPublica = `/produtos/${categoria?.slug}/${linha.slug}`;
---

<AdminLayout titulo={`Produto · ${linha.codigo}`}>
  <div class="acoes">
    <h1>{nomeProduto(pseudo)}</h1>
    <a class="voltar" href="/admin/produtos">← Todos os produtos</a>
  </div>

  {ok === '1' && <p class="flash" role="status">Produto salvo. O site público já reflete a mudança.</p>}
  {ok === 'img' && <p class="flash" role="status">Imagens atualizadas.</p>}
  {ok === 'criado' && <p class="flash" role="status">Rascunho criado — complete o conteúdo e publique aqui.</p>}
  {erro && <p class="flash erro" role="alert">{erro}</p>}

  <form method="POST">
    <input type="hidden" name="_acao" value="salvar" />

    <div class="editor-grid">
      <div>
        <div class="cartao-form">
          <h2>Dados básicos</h2>
          <div class="campos">
            <label class="campo">
              Código/modelo <span class="req" aria-hidden="true">*</span>
              <input type="text" name="codigo" value={linha.codigo} required />
            </label>
            <label class="campo">
              Etiqueta
              <input type="text" name="etiqueta" value={linha.etiqueta ?? ''} placeholder="Diesel, VSD…" />
            </label>
            <label class="campo">
              Tipo (termo semântico) <span class="req" aria-hidden="true">*</span>
              <input type="text" name="tipo" value={linha.tipo} required />
            </label>
            <label class="campo">
              Categoria <span class="req" aria-hidden="true">*</span>
              <select name="categoriaId" required>
                {categorias.map((c) => (
                  <option value={c.id} selected={c.id === linha.categoriaId}>
                    {c.nome}
                  </option>
                ))}
              </select>
            </label>
            <label class="campo">
              Marca
              <input type="text" name="marca" value={linha.marca ?? ''} placeholder="Atlas Copco (padrão)" />
            </label>
            <label class="campo">
              Nome de exibição (override)
              <input type="text" name="nome" value={linha.nome ?? ''} placeholder={`${linha.tipo} ${linha.codigo}`} />
            </label>
            <label class="campo">
              Slug (URL) <span class="req" aria-hidden="true">*</span>
              <input type="text" name="slug" value={linha.slug} required />
            </label>
            <label class="campo">
              Chips do card (vírgula)
              <input type="text" name="specsChips" value={(linha.specsChips ?? []).join(', ')} />
            </label>
          </div>
        </div>

        <div class="cartao-form">
          <h2>Conteúdo da página própria</h2>
          <p class="nota">
            A página própria só vai ao ar com os três blocos preenchidos — acompanhe no painel
            "Publicação" ao lado.
          </p>
          <div class="campos">
            <label class="campo largo">
              Pitch (1–2 frases de abertura; HTML simples permitido)
              <textarea name="pitch" style="min-height:72px">{linha.pitch ?? ''}</textarea>
            </label>
            <label class="campo largo">
              Descrição (150–400 palavras; parágrafos separados por linha em branco; o 1º começa com
              afirmação direta em &lt;b&gt;)
              <textarea name="descricao" style="min-height:190px">{descricaoTexto}</textarea>
            </label>
            <label class="campo largo">
              Especificações técnicas (uma por linha: <code>Rótulo | Valor</code>)
              <textarea name="especificacoes" style="min-height:140px" placeholder={'Potência | 144 kVA\nCombustível | Diesel'}>{especificacoesTexto}</textarea>
              <span class="dica">Specs de fonte oficial Atlas Copco — nunca inventar números.</span>
            </label>
          </div>
        </div>

        <div class="cartao-form">
          <h2>SEO</h2>
          <p class="nota">Vazio = o sistema deriva (preview no painel ao lado).</p>
          <div class="campos">
            <label class="campo largo">
              SEO Title
              <input type="text" name="seoTitle" value={linha.seoTitle ?? ''} maxlength="60" data-contador />
            </label>
            <label class="campo largo">
              Meta description
              <input
                type="text"
                name="seoDescription"
                value={linha.seoDescription ?? ''}
                maxlength="155"
                data-contador
              />
            </label>
          </div>
        </div>
      </div>

      <aside class="editor-lateral">
        <div class="cartao-form" style="margin-bottom:0">
          <h2>Publicação</h2>
          <p style="display:grid;gap:.6rem;margin-bottom:1rem">
            <label class="check">
              <input type="checkbox" name="publicado" checked={linha.publicado} />
              Publicado no site
            </label>
            <label class="check">
              <input type="checkbox" name="destaque" checked={linha.destaque} />
              Destaque no catálogo
            </label>
          </p>
          <h3 class="sub-painel">Página própria {completa ? '— completa' : '— incompleta'}</h3>
          <ul class="completude">
            <li class={temPitch ? 'feito' : ''}><span class="marca-check" aria-hidden="true"></span> Pitch</li>
            <li class={temDescricao ? 'feito' : ''}><span class="marca-check" aria-hidden="true"></span> Descrição</li>
            <li class={temSpecs ? 'feito' : ''}><span class="marca-check" aria-hidden="true"></span> Especificações</li>
            <li class={temImagem ? 'feito' : ''}><span class="marca-check" aria-hidden="true"></span> Imagem (recomendado)</li>
          </ul>
          <p class="nota" style="margin:0.75rem 0 0">
            {
              completa
                ? 'Este produto tem página no Google.'
                : 'Sem os 3 primeiros itens, o card aponta direto para o WhatsApp.'
            }
          </p>
          {
            linha.publicado && completa && (
              <a class="botao mini cinza" style="margin-top:0.75rem" href={urlPublica} target="_blank" rel="noopener">
                Ver no site ↗
              </a>
            )
          }
        </div>

        <div class="cartao-form" style="margin-bottom:0">
          <h2>Como o site vai exibir</h2>
          <dl class="derivados">
            <div>
              <dt>Nome</dt>
              <dd>{nomeProduto(pseudo)}</dd>
            </div>
            <div>
              <dt>H1 da página</dt>
              <dd>{h1Produto(pseudo)}</dd>
            </div>
            <div>
              <dt>Title <span class={tituloDerivado.length > 60 ? 'alem' : ''}>({tituloDerivado.length}/60)</span></dt>
              <dd>{tituloDerivado}</dd>
            </div>
            <div>
              <dt>Meta <span class={metaDerivada.length > 155 ? 'alem' : ''}>({metaDerivada.length}/155)</span></dt>
              <dd>{metaDerivada}</dd>
            </div>
            <div>
              <dt>Mensagem de WhatsApp</dt>
              <dd>{waMsgProduto(pseudo, categoria?.nome ?? '')}</dd>
            </div>
          </dl>
        </div>
      </aside>
    </div>

    <div class="barra-salvar">
      <button class="botao" type="submit">Salvar produto</button>
      <span class="lembrete">Salvar publica as mudanças imediatamente no site.</span>
    </div>
  </form>

  <div class="cartao-form" style="margin-top:1.5rem">
    <h2>Imagens</h2>
    {
      imagens.length === 0 && (
        <p class="nota">
          Nenhuma imagem ainda — o card aparece sem foto no catálogo. Envie a primeira abaixo
          (ela vira a principal).
        </p>
      )
    }
    <div class="galeria">
      {
        imagens.map((img) => (
          <div class="item">
            <img src={img.src} alt={img.alt ?? ''} loading="lazy" />
            <p style="margin:.45rem 0 0;min-height:1.3rem">
              {img.principal && <span class="badge dest">Principal</span>}
            </p>
            <form method="POST">
              <input type="hidden" name="_acao" value="img-alt" />
              <input type="hidden" name="imgId" value={img.id} />
              <input
                type="text"
                name="alt"
                value={img.alt ?? ''}
                aria-label="Texto alternativo da imagem"
                placeholder={`vazio = "${altImagem(pseudo, { src: img.src })}"`}
              />
              <button class="botao mini cinza" type="submit">Salvar alt</button>
            </form>
            <form method="POST" style="margin-top:.35rem">
              <input type="hidden" name="imgId" value={img.id} />
              {!img.principal && (
                <button class="botao mini cinza" name="_acao" value="img-principal" type="submit">
                  Tornar principal
                </button>
              )}
              <button
                class="botao mini perigo"
                name="_acao"
                value="img-remover"
                type="submit"
                onclick="return confirm('Remover esta imagem?')"
              >
                Remover
              </button>
            </form>
          </div>
        ))
      }
    </div>

    <form method="POST" enctype="multipart/form-data" class="form-upload">
      <input type="hidden" name="_acao" value="img-add" />
      <label class="campo">
        Nova imagem (JPG/PNG/WebP/AVIF · até 5 MB)
        <input type="file" name="arquivo" accept="image/jpeg,image/png,image/webp,image/avif" required />
      </label>
      <label class="campo">
        Alt (vazio = derivado)
        <input type="text" name="alt" />
      </label>
      <button class="botao" type="submit">Enviar imagem</button>
    </form>
  </div>

  <div class="cartao-form zona-perigo">
    <h2>Excluir produto</h2>
    <p class="nota">Remove o produto, suas imagens e especificações. Sem volta.</p>
    <form
      method="POST"
      onsubmit="return confirm('Excluir este produto e todas as suas imagens/specs? Esta ação não tem volta.')"
    >
      <input type="hidden" name="_acao" value="excluir" />
      <button class="botao perigo" type="submit">Excluir produto</button>
    </form>
  </div>
</AdminLayout>

<style>
  .sub-painel {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ink-2);
    margin-bottom: 0.6rem;
  }
  .form-upload {
    margin-top: 1.25rem;
    padding-top: 1.25rem;
    border-top: 1px dashed var(--line-strong);
    display: flex;
    gap: 0.85rem;
    flex-wrap: wrap;
    align-items: end;
  }
  .form-upload .campo { flex: 1; min-width: 220px; }
  .zona-perigo { border-color: color-mix(in srgb, var(--erro-ink) 35%, transparent); }
  .zona-perigo h2 { color: var(--erro-ink); }
</style>
