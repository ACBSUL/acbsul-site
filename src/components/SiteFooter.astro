---
// Rodapé global (fgrid + fbottom) + botão flutuante de WhatsApp.
// Links de categoria apontam para o filtro do catálogo (/produtos#slug).
import { empresa } from '../data/empresa';
import { categorias } from '../data/categorias';
import { carregarConfig } from '../lib/config';

const cfg = await carregarConfig();
---

<!-- ============ FOOTER ============ -->
<footer class="footer">
  <div class="container">
    <div class="fgrid">
      <div>
        <img
          class="flogo"
          src="/assets/logo-acbsul-light.svg"
          alt="ACB Sul Compressores e Geradores"
        />
        <p class="fabout">
          Compressores industriais, geradores e assistência técnica Atlas Copco. Tecnologia
          robusta, peças originais e suporte técnico para a indústria gaúcha e catarinense.
        </p>
        <span class="fseal">◇ Distribuidor Autorizado Atlas Copco</span>
      </div>
      <div>
        <h4>Navegação</h4>
        <ul>
          <li><a href="/quem-somos">A ACBSUL</a></li>
          <li><a href="/produtos">Produtos</a></li>
          <li><a href="/produtos#pecas">Peças</a></li>
          <li><a href="/#servicos">Serviços</a></li>
          <li><a href="/#faq">FAQ</a></li>
          <li><a href="/#contato">Orçamento</a></li>
        </ul>
      </div>
      <div>
        <h4>Produtos</h4>
        <ul class="fprod">
          {
            categorias.map((c) => (
              <li>
                <a href={`/produtos#${c.slug}`}>{c.nome}</a>
              </li>
            ))
          }
        </ul>
      </div>
      <div>
        <h4>Contato</h4>
        <ul class="fcontact">
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
              ><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"
              ></circle></svg
            ><span><b>Sede — {empresa.endereco.cidade}/{empresa.endereco.uf}</b>{empresa.endereco.rua}</span>
          </li>
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
              ><path
                d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13 1 .37 1.96.72 2.88a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.2-1.2a2 2 0 0 1 2.11-.45c.92.35 1.88.59 2.88.72A2 2 0 0 1 22 16.92z"
              ></path></svg
            ><span><b>{cfg.telefone}</b>Seg–Sex · 8h–12h / 13h–17h</span>
          </li>
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
              ><rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="m22 7-10 5L2 7"></path></svg
            ><span set:html={cfg.email.replace('@', '@<wbr>')}></span>
          </li>
        </ul>
      </div>
    </div>
    <div class="fbottom">
      <span>© <span id="yr"></span> ACB Sul Compressores e Geradores · {empresa.posicionamento}</span>
      <span>Atlas Copco® é marca registrada de seus respectivos titulares.</span>
      <span class="dev"
        >Desenvolvido por <a
          href="https://www.procuradaagencia.com.br/"
          target="_blank"
          rel="noopener">PROCURADA</a
        ></span
      >
    </div>
  </div>
</footer>

<!-- WhatsApp float -->
<a
  class="wa-float"
  data-wa-msg="Olá! Vim pelo site e gostaria de falar com a ACB Sul."
  aria-label="WhatsApp"
>
  <span class="wi"
    ><svg viewBox="0 0 24 24" fill="currentColor"
      ><path
        d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 0 1 8.413 3.488 11.82 11.82 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.51 5.26l-.999 3.648 3.978-1.605zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"
      ></path></svg
    ></span
  >
  <span class="wt">Falar no WhatsApp</span>
</a>

<script is:inline>
  document.getElementById('yr').textContent = new Date().getFullYear();
</script>
