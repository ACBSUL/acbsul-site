---
// Admin → Categorias: lista com link de edição (inclui config de WhatsApp).
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { carregarCategorias, carregarProdutos } from '../../../lib/catalogo';

export const prerender = false;

const categorias = await carregarCategorias();
const produtos = await carregarProdutos();
const nProdutos = new Map<string, number>();
for (const p of produtos) {
  nProdutos.set(p.categoria, (nProdutos.get(p.categoria) ?? 0) + 1);
}

const ok = Astro.url.searchParams.get('ok');
const erro = Astro.url.searchParams.get('erro');
---

<AdminLayout titulo="Categorias">
  <div class="acoes">
    <h1>Categorias</h1>
    <a class="botao" href="/admin/categorias/nova">+ Nova categoria</a>
    <p class="sub">
      Cada categoria define o WhatsApp que recebe os leads da sua linha de produtos.
    </p>
  </div>

  {ok === 'excluida' && <p class="flash" role="status">Categoria excluída.</p>}
  {
    erro === 'tem-produtos' && (
      <p class="flash erro" role="alert">
        Esta categoria tem produtos vinculados. Mova ou exclua os produtos antes de excluir a categoria.
      </p>
    )
  }

  <div class="tabela-rolagem">
    <table class="lista">
      <thead>
        <tr>
          <th scope="col">#</th>
          <th scope="col">Nome</th>
          <th scope="col">Produtos</th>
          <th scope="col">WhatsApp da categoria</th>
          <th scope="col">Status</th>
          <th scope="col"><span class="sr-only">Ações</span></th>
        </tr>
      </thead>
      <tbody>
        {
          categorias.map((c) => (
            <tr>
              <td>{c.ordem}</td>
              <td>
                <b>{c.nome}</b>
                <br />
                <span class="secundario">/{c.slug}</span>
              </td>
              <td>{nProdutos.get(c.slug) ?? 0}</td>
              <td>
                {c.whatsappNumero ? (
                  <span class="badge info">{c.whatsappNumero}</span>
                ) : (
                  <span class="secundario">número geral</span>
                )}
              </td>
              <td>
                {c.ativa ? <span class="badge ok">Ativa</span> : <span class="badge off">Oculta</span>}
              </td>
              <td>
                <div class="acoes-linha">
                  <a class="botao mini cinza" href={`/admin/categorias/${c.id}`}>
                    Editar
                  </a>
                  <form
                    method="POST"
                    action={`/admin/categorias/${c.id}`}
                    onsubmit="return confirm('Excluir esta categoria? Só é possível se não houver produtos vinculados.')"
                  >
                    <input type="hidden" name="_acao" value="excluir" />
                    <button class="botao-icone perigo" type="submit" title="Excluir categoria" aria-label={`Excluir ${c.nome}`}>
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 6h18" />
                        <path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6" />
                        <line x1="10" y1="11" x2="10" y2="17" />
                        <line x1="14" y1="11" x2="14" y2="17" />
                      </svg>
                    </button>
                  </form>
                </div>
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</AdminLayout>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }
  .acoes-linha { display: flex; gap: 0.45rem; align-items: center; }
  .acoes-linha form { margin: 0; }
  .botao-icone {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    flex: none;
    border: 1px solid var(--line-strong);
    border-radius: var(--r);
    background: var(--surface);
    color: var(--ink-2);
    cursor: pointer;
    transition: background var(--t), border-color var(--t), color var(--t);
  }
  .botao-icone svg { width: 17px; height: 17px; }
  .botao-icone.perigo { color: var(--erro-ink); }
  .botao-icone.perigo:hover { background: var(--erro-bg); border-color: currentColor; }
</style>
