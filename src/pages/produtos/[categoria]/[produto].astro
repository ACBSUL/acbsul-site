---
import SiteLayout from '../../../layouts/SiteLayout.astro';
import SiteNav from '../../../components/SiteNav.astro';
import SiteFooter from '../../../components/SiteFooter.astro';
import { empresa, entityBlockTexto } from '../../../data/empresa';
import {
  marcaDe,
  nomeProduto,
  h1Produto,
  codigoEtiqueta,
  imagemPrincipal,
  altImagem,
  temPaginaPropria,
  urlProduto,
  waMsgProduto,
  seoTitleProduto,
  seoDescriptionProduto,
} from '../../../data/produtos';
import { carregarCategorias, carregarProdutos } from '../../../lib/catalogo';

// Etapa C: PDP lê do banco (SSR — HTML completo servido). Existe página
// quando o conteúdo está completo (pitch + descrição + especificações).
export const prerender = false;

const categorias = (await carregarCategorias()).filter((c) => c.ativa);
const todos = (await carregarProdutos()).filter((x) => x.publicado !== false);

const p = todos.find(
  (x) => x.slug === Astro.params.produto && x.categoria === Astro.params.categoria,
);
const categoria = categorias.find((c) => c.slug === Astro.params.categoria);

if (!p || !categoria || !temPaginaPropria(p)) {
  return new Response('Página não encontrada', {
    status: 404,
    headers: { 'Content-Type': 'text/plain; charset=utf-8' },
  });
}

const urlAbs = `${empresa.url}${urlProduto(p)}`;
const img = imagemPrincipal(p);

// relacionados: mesma categoria, até 3
const relacionados = todos.filter((x) => x.categoria === p.categoria && x.slug !== p.slug).slice(0, 3);

// Schema — Product + BreadcrumbList (catálogo lead-gen, sem preço/checkout)
const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: h1Produto(p),
  image: img ? new URL(img.src, empresa.url).href : undefined,
  description: seoDescriptionProduto(p),
  mpn: p.codigo,
  brand: { '@type': 'Brand', name: marcaDe(p) },
  category: categoria.nome,
  url: urlAbs,
};
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Início', item: empresa.url },
    { '@type': 'ListItem', position: 2, name: 'Produtos', item: `${empresa.url}/produtos` },
    {
      '@type': 'ListItem',
      position: 3,
      name: categoria.nome,
      item: `${empresa.url}/produtos#${categoria.slug}`,
    },
    { '@type': 'ListItem', position: 4, name: h1Produto(p), item: urlAbs },
  ],
};
---

<SiteLayout
  title={seoTitleProduto(p)}
  description={seoDescriptionProduto(p)}
  ogImage={img?.src}
  page="produtos"
>
  <script
    type="application/ld+json"
    is:inline
    slot="head"
    set:html={JSON.stringify(productSchema)}
  />
  <script
    type="application/ld+json"
    is:inline
    slot="head"
    set:html={JSON.stringify(breadcrumbSchema)}
  />

  <SiteNav />

  <main>
    <!-- ============ BREADCRUMB (faixa escura sob o nav fixo) ============ -->
    <section class="crumb-band">
      <div class="container">
        <nav class="breadcrumb" aria-label="Trilha">
          <a href="/">Início</a><span class="sep">/</span>
          <a href="/produtos">Produtos</a><span class="sep">/</span>
          <a href={`/produtos#${categoria.slug}`}>{categoria.nome}</a><span class="sep">/</span>
          <span class="current">{codigoEtiqueta(p)}</span>
        </nav>
      </div>
    </section>

    <!-- ============ PDP TOP ============ -->
    <section class="section" style="padding-block:clamp(40px,5vw,64px)">
      <div class="container">
        <div class="pdp-top">
          <!-- galeria -->
          <div class="gallery">
            <div class="gal-main">
              {img && <img src={img.src} alt={altImagem(p, img)} fetchpriority="high" />}
            </div>
          </div>

          <!-- info -->
          <div class="pdp-info">
            <span class="code">{categoria.nome}</span>
            <h1>{h1Produto(p)}</h1>
            <p class="pitch" set:html={p.pitch} />

            <div class="pdp-cta">
              <button class="btn btn-accent btn-lg" id="abrirLead" type="button"
                ><span class="ai"
                  ><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"
                    ><path d="M5 12h14M13 6l6 6-6 6"></path></svg
                  ></span
                >Solicitar mais informações</button
              >
              <!-- WhatsAppCTA por categoria (PRD §8): número/mensagem vêm da config do admin -->
              <a
                class="btn btn-wa btn-lg"
                data-wa-msg={categoria.whatsappMensagem || waMsgProduto(p, categoria.nome)}
                data-wa-num={categoria.whatsappNumero || undefined}
                >Falar com especialista</a
              >
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ ESPECIFICAÇÕES + DESCRIÇÃO ============ -->
    <section class="section tight" style="background:var(--bg-2)">
      <div class="container">
        <div class="pdp-detail-grid">
          <div>
            <table class="spec-table">
              <caption>Especificações técnicas</caption>
              <tbody>
                {
                  (p.especificacoes ?? []).map((s) => (
                    <tr>
                      <th>{s.rotulo}</th>
                      <td>{s.valor}</td>
                    </tr>
                  ))
                }
              </tbody>
            </table>
            <p class="form-note" style="margin-top:12px">
              Especificações de referência. Valores exatos confirmados na proposta conforme
              configuração e tensão da rede.
            </p>
          </div>

          <div class="pdp-desc">
            <h2>Sobre o {p.codigo}</h2>
            {(p.descricao ?? []).map((par) => <p set:html={par} />)}
          </div>
        </div>
      </div>
    </section>

    <!-- ============ RELACIONADOS ============ -->
    {
      relacionados.length > 0 && (
        <section class="section tight" style="background:var(--bg-2)">
          <div class="container">
            <div class="sec-head left" style="margin-bottom:28px">
              <span class="eyebrow">Relacionados</span>
              <h2>Outros equipamentos de {categoria.nome}</h2>
            </div>
            <div class="grid cols-3">
              {relacionados.map((r) => {
                const rImg = imagemPrincipal(r);
                const rUrl = temPaginaPropria(r) ? urlProduto(r) : null;
                return (
                  <article class="prod-card">
                    {rUrl ? (
                      <a class="pmedia" href={rUrl}>
                        {rImg && <img src={rImg.src} alt={altImagem(r, rImg)} loading="lazy" decoding="async" />}
                      </a>
                    ) : (
                      <div class="pmedia">
                        {rImg && <img src={rImg.src} alt={altImagem(r, rImg)} loading="lazy" decoding="async" />}
                      </div>
                    )}
                    <div class="pbody">
                      <span class="code">{codigoEtiqueta(r)}</span>
                      <h3>{nomeProduto(r)}</h3>
                      <div class="spec-chips">
                        {r.specsChips.map((s) => (
                          <span>{s}</span>
                        ))}
                      </div>
                      <div class="pfoot">
                        {rUrl ? (
                          <a class="link-arrow" href={rUrl}>
                            Ver detalhes{' '}
                            <span class="dot">
                              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M5 12h14M13 6l6 6-6 6" />
                              </svg>
                            </span>
                          </a>
                        ) : (
                          <a
                            class="link-arrow"
                            data-wa-msg={waMsgProduto(r, categoria.nome)}
                            data-wa-num={categoria.whatsappNumero || undefined}
                          >
                            Solicitar orçamento{' '}
                            <span class="dot">
                              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M5 12h14M13 6l6 6-6 6" />
                              </svg>
                            </span>
                          </a>
                        )}
                      </div>
                    </div>
                  </article>
                );
              })}
            </div>
            <div class="center-cta">
              <a class="btn btn-outline btn-lg" href={`/produtos#${categoria.slug}`}>
                Ver toda a linha
              </a>
            </div>
          </div>
        </section>
      )
    }

    <!-- ============ ENTITYBLOCK (rodapé da página de destino) ============ -->
    <section class="entity-strip" aria-label="Sobre a ACB Sul">
      <div class="container">
        <div class="inner">
          <span class="eyebrow">A ACB Sul</span>
          <p>{entityBlockTexto}</p>
        </div>
      </div>
    </section>
  </main>

  <!-- ============ POPUP: SOLICITAR MAIS INFORMAÇÕES (LeadForm) ============ -->
  <div
    class="lead-modal"
    id="leadModal"
    role="dialog"
    aria-modal="true"
    aria-label={`Solicitar mais informações — ${nomeProduto(p)}`}
  >
    <div class="lead-dialog">
      <div class="lead-head">
        {img && <img src={img.src} alt={altImagem(p, img)} />}
        <span class="lt"><span>{codigoEtiqueta(p)}</span><b>{nomeProduto(p)}</b></span>
        <button class="lead-close" type="button" data-close aria-label="Fechar">&times;</button>
      </div>
      <form data-leadform novalidate>
        <h3>Solicitar mais informações</h3>
        <p class="sub">Retornamos em horário comercial.</p>
        <input type="hidden" name="produto" value={nomeProduto(p)} />
        <div class="frow">
          <div class="field">
            <label>Nome <span class="req">*</span></label><input
              type="text"
              name="nome"
              required
              placeholder="Seu nome"
            /><span class="err">Informe seu nome.</span>
          </div>
          <div class="field">
            <label>Telefone <span class="req">*</span></label><input
              type="tel"
              name="telefone"
              required
              placeholder="(51) 9 0000-0000"
            /><span class="err">Informe um telefone.</span>
          </div>
        </div>
        <div class="frow">
          <div class="field">
            <label>E-mail <span class="req">*</span></label><input
              type="email"
              name="email"
              required
              placeholder="voce@empresa.com.br"
            /><span class="err">E-mail inválido.</span>
          </div>
          <div class="field">
            <label>Interesse</label>
            <select name="interesse">
              <option>Compra</option><option>Locação</option><option>Compra ou locação</option>
            </select>
          </div>
        </div>
        <div class="field">
          <label>Mensagem</label><textarea
            name="mensagem"
            placeholder="Vazão/pressão necessária, local de uso, prazo..."></textarea>
        </div>
        <button type="submit" class="btn btn-accent btn-block"
          ><span class="ai"
            ><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"
              ><path d="M5 12h14M13 6l6 6-6 6"></path></svg
            ></span
          >Enviar solicitação</button
        >
        <p class="form-note">
          Ao enviar, você concorda em ser contatado pela ACB Sul. Não compartilhamos seus dados.
        </p>
      </form>
      <div class="form-ok">
        <div class="ok">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"
            ><path d="M20 6 9 17l-5-5"></path></svg
          >
        </div>
        <h3>Solicitação enviada!</h3>
        <p style="color:var(--ink-2)">
          Recebemos seu pedido sobre o {nomeProduto(p)}. Um especialista da ACB Sul retornará em breve.
        </p>
      </div>
    </div>
  </div>

  <SiteFooter />

  <!-- abre/fecha o popup de solicitação -->
  <script is:inline>
    (function () {
      var modal = document.getElementById('leadModal');
      var abrir = document.getElementById('abrirLead');
      if (!modal || !abrir) return;
      function open() {
        modal.classList.add('open');
        document.body.style.overflow = 'hidden';
      }
      function close() {
        modal.classList.remove('open');
        document.body.style.overflow = '';
      }
      abrir.addEventListener('click', open);
      modal.addEventListener('click', function (e) {
        if (e.target === modal || e.target.closest('[data-close]')) close();
      });
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') close();
      });
    })();
  </script>
</SiteLayout>
