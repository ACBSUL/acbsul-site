# Copie para .env e preencha. O .env real NUNCA é commitado.

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# String de conexão Postgres (Supabase → Connect → ORMs → Drizzle, transaction pooler)
DATABASE_URL=

# Better-Auth (login do admin)
# Gerar segredo: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Local: http://localhost:5030 — Produção: https://dominio-do-site
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=
