---
// Admin → Produtos: lista com busca e filtro por categoria.
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { nomeProduto, imagemPrincipal, temPaginaPropria } from '../../../data/produtos';
import { carregarCategorias, carregarProdutos } from '../../../lib/catalogo';

export const prerender = false;

const categorias = await carregarCategorias();
const todos = await carregarProdutos();

const q = (Astro.url.searchParams.get('q') ?? '').trim().toLowerCase();
const cat = Astro.url.searchParams.get('cat') ?? '';

let itens = todos;
if (cat) itens = itens.filter((p) => p.categoria === cat);
if (q) {
  itens = itens.filter((p) => `${p.nome} ${p.slug}`.toLowerCase().includes(q));
}
const nomeCategoria = new Map(categorias.map((c) => [c.slug, c.nomeCurto]));
const excluido = Astro.url.searchParams.get('ok') === 'excluido';
const filtrando = Boolean(q || cat);
---

<AdminLayout titulo="Produtos">
  <div class="acoes">
    <h1>
      Produtos
      <span class="contagem">{filtrando ? `${itens.length} de ${todos.length}` : todos.length}</span>
    </h1>
    <a class="botao" href="/admin/produtos/novo">+ Novo produto</a>
  </div>

  {excluido && <p class="flash" role="status">Produto excluído.</p>}

  <form method="GET" class="toolbar" role="search">
    <input
      type="search"
      name="q"
      value={q}
      placeholder="Buscar por código, tipo ou nome…"
      aria-label="Buscar produtos"
    />
    <select name="cat" aria-label="Filtrar por categoria">
      <option value="">Todas as categorias</option>
      {categorias.map((c) => (
        <option value={c.slug} selected={c.slug === cat}>
          {c.nome}
        </option>
      ))}
    </select>
    <button class="botao cinza" type="submit">Filtrar</button>
    {filtrando && <a class="limpar" href="/admin/produtos">Limpar</a>}
  </form>

  <div class="tabela-rolagem">
    <table class="lista">
      <thead>
        <tr>
          <th scope="col"><span class="sr-only">Foto</span></th>
          <th scope="col">Produto</th>
          <th scope="col">Categoria</th>
          <th scope="col">Status</th>
          <th scope="col"><span class="sr-only">Ações</span></th>
        </tr>
      </thead>
      <tbody>
        {
          itens.length === 0 && (
            <tr>
              <td colspan="5" class="vazio">
                <b>Nenhum produto encontrado.</b>
                <br />
                Tente outra busca ou <a href="/admin/produtos">limpe os filtros</a>.
              </td>
            </tr>
          )
        }
        {
          itens.map((p) => {
            const img = imagemPrincipal(p);
            return (
              <tr>
                <td style="width:62px">
                  {img && <img class="mini-foto" src={img.src} alt="" loading="lazy" />}
                </td>
                <td>
                  <a class="nome-produto" href={`/admin/produtos/${p.id}`}>
                    {nomeProduto(p)}
                  </a>
                  <br />
                  <span class="secundario">
                    {p.slug ? `/${p.slug}` : 'sem slug — defina na edição'}
                  </span>
                </td>
                <td>{nomeCategoria.get(p.categoria) ?? p.categoria}</td>
                <td>
                  {p.publicado !== false ? (
                    <span class="badge ok">Publicado</span>
                  ) : (
                    <span class="badge off">Rascunho</span>
                  )}
                  {p.destaque && <span class="badge dest">Destaque</span>}
                  {temPaginaPropria(p) && <span class="badge info">Página própria</span>}
                </td>
                <td>
                  <div class="acoes-linha">
                    <a class="botao mini cinza" href={`/admin/produtos/${p.id}`}>
                      Editar
                    </a>
                    <form
                      method="POST"
                      action={`/admin/produtos/${p.id}`}
                      onsubmit="return confirm('Excluir este produto? Remove imagens e especificações. Esta ação não tem volta.')"
                    >
                      <input type="hidden" name="_acao" value="excluir" />
                      <button class="botao mini perigo" type="submit">Excluir</button>
                    </form>
                  </div>
                </td>
              </tr>
            );
          })
        }
      </tbody>
    </table>
  </div>
</AdminLayout>

<style>
  .contagem {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--ink-2);
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.1rem 0.6rem;
    vertical-align: 3px;
    margin-left: 0.4rem;
  }
  .toolbar { display: flex; gap: 0.6rem; flex-wrap: wrap; align-items: center; margin-bottom: 1rem; }
  .toolbar input[type='search'] {
    flex: 1;
    min-width: 220px;
    padding: 0.6rem 0.8rem;
    border: 1px solid var(--line-strong);
    border-radius: var(--r);
    font-size: 1rem;
    font-family: inherit;
  }
  .toolbar select {
    padding: 0.6rem 0.8rem;
    border: 1px solid var(--line-strong);
    border-radius: var(--r);
    font-size: 0.95rem;
    font-family: inherit;
    background: var(--surface);
  }
  .limpar { color: var(--ink-2); font-size: 0.9rem; }
  .acoes-linha { display: flex; gap: 0.4rem; align-items: center; }
  .acoes-linha form { margin: 0; }
  .nome-produto { color: var(--ink); font-weight: 700; text-decoration: none; }
  .nome-produto:hover { color: var(--accent-strong); }
  .vazio a { color: var(--accent-strong); }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }
</style>
