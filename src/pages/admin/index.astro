---
// Dashboard do admin — visão de trabalho, não de vaidade: o que está
// publicado e o que precisa de ação (princípio 2 do PRODUCT.md:
// "publicar sem medo" = estado público sempre visível).
import { eq } from 'drizzle-orm';
import AdminLayout from '../../layouts/AdminLayout.astro';
import { temPaginaPropria } from '../../data/produtos';
import { carregarCategorias, carregarProdutos } from '../../lib/catalogo';
import { db, tabelas } from '../../db';

export const prerender = false;

const categorias = await carregarCategorias();
const produtos = await carregarProdutos();
const leadsNovos = await db
  .select({ id: tabelas.leads.id })
  .from(tabelas.leads)
  .where(eq(tabelas.leads.atendido, false));

const publicados = produtos.filter((p) => p.publicado !== false);
const rascunhos = produtos.filter((p) => p.publicado === false);
const semImagem = publicados.filter((p) => p.imagens.length === 0);
const semPagina = publicados.filter((p) => !temPaginaPropria(p));
const semWhatsapp = categorias.filter((c) => c.ativa && !c.whatsappNumero);
const usuario = Astro.locals.user;
const primeiroNome = usuario?.name?.split(' ')[0] ?? 'admin';
---

<AdminLayout titulo="Início">
  <div class="acoes">
    <h1>Olá, {primeiroNome}</h1>
    <a class="botao" href="/admin/produtos/novo">+ Novo produto</a>
  </div>

  <div class="resumo">
    <a href="/admin/leads">
      <b>{leadsNovos.length}</b> leads novos
    </a>
    <a href="/admin/produtos">
      <b>{publicados.length}</b> produtos publicados
    </a>
    <a href="/admin/categorias">
      <b>{categorias.filter((c) => c.ativa).length}</b> categorias ativas
    </a>
  </div>

  <h2 class="titulo-bloco">Para fazer</h2>
  <ul class="pendencias">
    <li>
      <a href="/admin/leads">
        <span class={`num ${leadsNovos.length === 0 ? 'zero' : ''}`}>{leadsNovos.length}</span>
        <span class="texto">
          <b>Leads aguardando atendimento</b>
          <span>
            {
              leadsNovos.length === 0
                ? 'Nenhuma solicitação nova esperando retorno.'
                : 'Solicitações recebidas pelo site — retorne o quanto antes.'
            }
          </span>
        </span>
      </a>
    </li>
    <li>
      <a href="/admin/produtos">
        <span class={`num ${rascunhos.length === 0 ? 'zero' : ''}`}>{rascunhos.length}</span>
        <span class="texto">
          <b>Rascunhos não publicados</b>
          <span>
            {
              rascunhos.length === 0
                ? 'Tudo publicado — nada esperando.'
                : `${rascunhos
                    .slice(0, 3)
                    .map((p) => p.nome)
                    .join(', ')}${rascunhos.length > 3 ? ` e mais ${rascunhos.length - 3}` : ''}`
            }
          </span>
        </span>
      </a>
    </li>
    <li>
      <a href="/admin/produtos">
        <span class={`num ${semImagem.length === 0 ? 'zero' : ''}`}>{semImagem.length}</span>
        <span class="texto">
          <b>Publicados sem imagem</b>
          <span>
            {
              semImagem.length === 0
                ? 'Todos os produtos publicados têm foto.'
                : 'O card aparece sem foto no catálogo.'
            }
          </span>
        </span>
      </a>
    </li>
    <li>
      <a href="/admin/produtos">
        <span class={`num ${semPagina.length === 0 ? 'zero' : ''}`}>{semPagina.length}</span>
        <span class="texto">
          <b>Sem página própria</b>
          <span>
            {
              semPagina.length === 0
                ? 'Todos têm pitch, descrição e especificações.'
                : 'Complete pitch + descrição + specs para ganhar página no Google.'
            }
          </span>
        </span>
      </a>
    </li>
    <li>
      <a href="/admin/categorias">
        <span class={`num ${semWhatsapp.length === 0 ? 'zero' : ''}`}>{semWhatsapp.length}</span>
        <span class="texto">
          <b>Categorias sem WhatsApp próprio</b>
          <span>
            {
              semWhatsapp.length === 0
                ? 'Todas roteiam para um especialista.'
                : 'Leads dessas categorias caem no número geral da empresa.'
            }
          </span>
        </span>
      </a>
    </li>
  </ul>
</AdminLayout>

<style>
  .resumo { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 2rem; }
  .resumo a {
    text-decoration: none;
    color: var(--ink-2);
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r);
    padding: 0.6rem 1rem;
    font-size: 0.92rem;
    transition: border-color var(--t);
  }
  .resumo a:hover { border-color: var(--accent); }
  .resumo b { color: var(--ink); font-size: 1.05rem; margin-right: 0.25rem; }
  .titulo-bloco { font-size: 1.02rem; font-weight: 700; margin-bottom: 0.85rem; }
</style>
